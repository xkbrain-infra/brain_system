{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "greptile@claude-plugins-official": true
  },
  "language": "中文",
  "mcpServers": {
    "mcp-brain_ipc_c": {
      "command": "/brain/bin/mcp/mcp-brain_ipc_c",
      "args": [],
      "env": {
        "BRAIN_AGENT_NAME": "claude",
        "BRAIN_DAEMON_AUTOSTART": "1"
      }
    },
    "google-drive": {
      "command": "npx",
      "args": ["-y", "aegaea-drive-mcp"],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "/brain/secrets/google_oauth/credentials.json",
        "GOOGLE_DRIVE_TOKEN_PATH": "/brain/secrets/google_oauth/token.json"
      }
    }
  }
}
