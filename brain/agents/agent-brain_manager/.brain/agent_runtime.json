      "BRAIN_ROLE_DEFAULT_SKILLS": "preset,brain-publish,lep,agentctl,ipc,workflow-orchestrator,task-manager,spawn-orchestrator",
      "BRAIN_AGENT_EXTRA_SKILLS": "validate-alignment",
      "BRAIN_LEP_BINDINGS_FILE": "/xkagent_infra/brain/infrastructure/config/agentctl/lep_bindings.yaml",
