{
  "permissions": {
    "allow": [
      "Bash:*:*",
      "Read:*:*",
      "Edit:*:*",
      "Write:*:*",
      "Glob:*:*",
      "Grep:*:*",
      "Task:*:*",
      "Skill:*:*",
      "mcp__*:*",
      "AskUserQuestion:*:*",
      "NotebookEdit:*:*"
    ],
    "defaultMode": "bypassPermissions"
  },
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:8210",
    "ANTHROPIC_AUTH_TOKEN": "bgw-client-v1-6eabce592a2d0c76fd809e69222e7d2e",
    "ANTHROPIC_MODEL": "openai/gpt-5.4",
    "ANTHROPIC_SMALL_FAST_MODEL": "openai/gpt-5.4",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "openai/gpt-5.4",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "openai/gpt-5.4",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "openai/gpt-5.4",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "BRAIN_SKILL_BINDINGS_FILE": "/xkagent_infra/brain/infrastructure/config/agentctl/skill_bindings.yaml",
    "BRAIN_ENABLED_SKILLS": "doc-search,lep,tmux,sandbox,task-manager",
    "BRAIN_ROLE_DEFAULT_SKILLS": "lep,doc-search,tmux,sandbox,task-manager",
    "BRAIN_AGENT_EXTRA_SKILLS": "doc-search",
    "BRAIN_LEP_BINDINGS_FILE": "/xkagent_infra/brain/infrastructure/config/agentctl/lep_bindings.yaml",
    "BRAIN_ENABLED_LEP_PROFILES": "workspace-dev",
    "BRAIN_ROLE_DEFAULT_LEP_PROFILES": "workspace-dev"
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name // \"Claude\"'); dir=$(echo \"$input\" | jq -r '.workspace.current_dir // \"~\"'); used=$(echo \"$input\" | jq -r 'def token_pct($ctx): if (($ctx.context_window_size // 0) | tonumber) > 0 then ((($ctx.current_usage.input_tokens // $ctx.total_input_tokens // 0) + ($ctx.current_usage.output_tokens // $ctx.total_output_tokens // 0) + ($ctx.current_usage.cache_creation_input_tokens // 0) + ($ctx.current_usage.cache_read_input_tokens // 0)) / ($ctx.context_window_size | tonumber) * 100) else empty end; (.context_window.used_percentage // .context_window.percent_used // .contextWindow.usedPercentage // .contextWindow.percentUsed // .session.context_window.used_percentage // .usage.context_window.used_percentage // empty) as $reported | (.context_window // .contextWindow // .session.context_window // .usage.context_window // {}) as $ctx | if ($reported | tostring | length) > 0 then $reported else token_pct($ctx) end'); if [ -n \"$used\" ]; then printf \"%s | %s | Context: %.1f%% used\" \"$model\" \"$dir\" \"$used\"; else printf \"%s | %s | Context: n/a\" \"$model\" \"$dir\"; fi"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "greptile@claude-plugins-official": true
  },
  "language": "中文",
  "mcpServers": {
    "mcp-brain_ipc": {
      "command": "/brain/bin/mcp/mcp-brain_ipc_c",
      "args": [],
      "env": {
        "BRAIN_AGENT_NAME": "agent-brain_codex_foos",
        "BRAIN_DAEMON_AUTOSTART": "0"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "spinnerTipsEnabled": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Glob|Grep|Read|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/brain/base/hooks/pre_tool_use",
            "timeout": 5000,
            "description": "LEP Engine - dev-brain PreToolUse",
            "env": {
              "BRAIN_AGENT_NAME": "agent-brain_codex_foos",
              "BRAIN_AGENT_ROLE": "dev",
              "BRAIN_AGENT_GROUP": "brain",
              "BRAIN_SCOPE_PATH": "/xkagent_infra/brain",
              "BRAIN_LEP_BINDINGS_FILE": "/xkagent_infra/brain/infrastructure/config/agentctl/lep_bindings.yaml",
              "BRAIN_ROLE_DEFAULT_LEP_PROFILES": "workspace-dev",
              "BRAIN_ENABLED_LEP_PROFILES": "workspace-dev"
            }
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Glob|Grep|Read|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/brain/base/hooks/post_tool_use",
            "timeout": 5000,
            "description": "LEP Engine - dev-brain PostToolUse audit",
            "env": {
              "BRAIN_AGENT_NAME": "agent-brain_codex_foos",
              "BRAIN_AGENT_ROLE": "dev",
              "BRAIN_AGENT_GROUP": "brain",
              "BRAIN_SCOPE_PATH": "/xkagent_infra/brain",
              "BRAIN_LEP_BINDINGS_FILE": "/xkagent_infra/brain/infrastructure/config/agentctl/lep_bindings.yaml",
              "BRAIN_ROLE_DEFAULT_LEP_PROFILES": "workspace-dev",
              "BRAIN_ENABLED_LEP_PROFILES": "workspace-dev"
            }
          }
        ]
      }
    ]
  }
}
