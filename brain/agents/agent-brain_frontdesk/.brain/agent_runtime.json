    ],
    "env": {
      "IS_SANDBOX": "1",
      "BRAIN_TRANSPORT_MODE": "proxy",
      "BRAIN_AGENT_NAME": "agent-brain_frontdesk",
      "ANTHROPIC_BASE_URL": "http://127.0.0.1:8210",
      "ANTHROPIC_AUTH_TOKEN": "bgw-client-v1-fee4665eb5f723a9a80dd97cbbb3ad27",
      "ANTHROPIC_MODEL": "copilot/gpt-5-mini",
      "ANTHROPIC_SMALL_FAST_MODEL": "copilot/gpt-5-mini",
      "ANTHROPIC_DEFAULT_SONNET_MODEL": "copilot/gpt-5-mini",
      "ANTHROPIC_DEFAULT_OPUS_MODEL": "copilot/gpt-5-mini",
      "ANTHROPIC_DEFAULT_HAIKU_MODEL": "copilot/gpt-5-mini",
      "API_TIMEOUT_MS": "3000000",
      "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
      "BRAIN_SKILL_BINDINGS_FILE": "/xkagent_infra/brain/infrastructure/config/agentctl/skill_bindings.yaml",
      "BRAIN_ENABLED_SKILLS": "lep,ipc,task-manager",
      "BRAIN_ROLE_DEFAULT_SKILLS": "lep,ipc,task-manager",
      "BRAIN_LEP_BINDINGS_FILE": "/xkagent_infra/brain/infrastructure/config/agentctl/lep_bindings.yaml",
      "BRAIN_ENABLED_LEP_PROFILES": "frontdesk-safe",
      "BRAIN_ROLE_DEFAULT_LEP_PROFILES": "frontdesk-safe"
    },
    "agent_type": "copilot",
    "use_claude_cli": true
  }
