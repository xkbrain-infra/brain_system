    "resolved_skills": [
      "lep",
      "ipc",
      "task-manager"
    ],
    "role_skills": [
      "lep",
      "ipc",
      "task-manager"
    ],
    "agent_skills": [],
    "workflow_skills": []
  },
  "lep_bindings": {
