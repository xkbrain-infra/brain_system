agents_registry:
  version: "2.1"
  updated: "2026-02-28"

group_meta:
  brain:
    type: coding
    description: Brain core management group
  system:
    type: coding
    description: Brain system operations group

groups:
  brain:
    - name: agent-brain_manager
      description: Brain manager (resident)
      role: manager
      scope: group
      group: brain
      path: /groups/brain/agents/agent-brain_manager
      agent_type: minimax
      agent_cli: claude
      agent_model: MiniMax-M2.5
      tmux_session: agent-brain_manager
      cwd: /groups/brain/agents/agent-brain_manager
      cli_args:
        - --dangerously-skip-permissions
      env:
        IS_SANDBOX: 1
      export_cmd:
        BRAIN_AGENT_NAME: agent-brain_manager
      desired_state: running
      status: active
      required: false

  system:
    - name: agent-system_pmo
      description: System PMO (resident)
      role: pmo
      scope: group
      group: system
      path: /groups/system/agents/agent-system_pmo
      agent_type: claude
      model: Sonnet
      tmux_session: agent-system_pmo
      cwd: /groups/system/agents/agent-system_pmo
      cli_args:
        - --dangerously-skip-permissions
      env:
        IS_SANDBOX: 1
      export_cmd:
        BRAIN_AGENT_NAME: agent-system_pmo
      desired_state: running
      status: active
      required: false

    - name: agent-system_devops
      description: System devops (resident)
      role: devops
      scope: group
      group: system
      path: /groups/system/agents/agent-system_devops
      agent_type: claude
      model: Sonnet
      tmux_session: agent-system_devops
      cwd: /groups/system/agents/agent-system_devops
      cli_args:
        - --dangerously-skip-permissions
      env:
        IS_SANDBOX: 1
      export_cmd:
        BRAIN_AGENT_NAME: agent-system_devops
      desired_state: running
      status: active
      required: false
