    - post_tool_use
    - session_start
    desired_state: running
    status: active
    capabilities:
    - quality_assurance
    - testing
    - test_case_design
    - functional_testing
    - regression_testing
    - bug_reporting
    - test_automation
    tags:
    - '#qa'
    - '#testing'
    - '#quality'
    - '#review'
    - '#automation'
  - name: agent_system_creator
