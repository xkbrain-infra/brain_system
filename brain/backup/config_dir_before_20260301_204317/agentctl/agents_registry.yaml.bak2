agents_registry:
  version: '2.1'
  updated: '2026-02-14'
  schema:
    agent_spec:
      name: string
      agent_type: enum
      agent_cli: enum
      agent_model: string
      cli_type: enum
      model: string
      tmux_session: string
      cwd: string
      cli_args: list[string]
      env: map[string, string]
      export_cmd: map[string, string]
      config:
        config_home: string
        mcp_config: string
      required: bool
      desired_state: enum
      status: enum
      capabilities: list[string]
      tags: list[string]
  cli_type_rules:
    claude: 'Use Claude Code CLI: claude --model <model>'
    claude_code: Alias for 'claude'
    native: 'Use model''s native CLI: <agent_type> (e.g., codex, kimi, minimax)'
    default: If not specified, infer from agent_type (backward compatible)
group_meta:
  brain_system:
    type: coding
    description: "Brain \u7CFB\u7EDF\u6838\u5FC3 - Agent \u57FA\u7840\u8BBE\u65BD\u3001\
      \u534F\u8C03\u3001\u8FD0\u7EF4"
  xkquant:
    type: coding
    description: "\u91CF\u5316\u4EA4\u6613\u7CFB\u7EDF - \u7B56\u7565\u5F00\u53D1\u3001\
      \u56DE\u6D4B\u3001\u6570\u636E\u5206\u6790"
groups:
  brain_system:
  - name: agent_system_pmo
    description: "brain_system \u7684\u9879\u76EE\u7BA1\u7406 Agent - \u8D1F\u8D23\
      \u4EFB\u52A1\u534F\u8C03\u3001\u8FDB\u5EA6\u8DDF\u8E2A\u3001\u8D44\u6E90\u8C03\
      \u5EA6"
    role: pmo
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_pmo
    agent_type: claude
    model: Sonnet
    tmux_session: agent_system_pmo
    cwd: /brain/groups/org/brain_system/agents/agent_system_pmo
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_pmo
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    - session_end
    required: false
    desired_state: running
    status: active
    capabilities:
    - project_management
    - task_coordination
    - progress_tracking
    - resource_allocation
    - risk_assessment
    tags:
    - '#pmo'
    - '#coordinator'
    - '#manager'
  - name: agent_brain_frontdesk
    description: "Agent Brain \u4E13\u7528 \u524D\u53F0 - \u6536\u53D1 \u524D\u53F0\
      /Telegram Bot, etc"
    role: frontdesk
    scope: group
    group: brain_system
    path: /brain/groups/org/brain/agents/agent_brain_frontdesk
    agent_type: claude
    model: Haiku
    tmux_session: agent_brain_frontdesk
    cwd: /brain/groups/org/brain/agents/agent_brain_frontdesk
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_brain_frontdesk
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    gateway_bindings:
    - service_gateway_telegram
    required: false
    desired_state: running
    status: active
    capabilities:
    - message_routing
    - telegram_gateway
    - fallback_handler
    - agent_dispatch
    tags:
    - '#operator'
    - '#router'
    - '#gateway'
  - name: agent_system_devops
    description: "Agent Brain \u4E13\u7528 devops Agent - \u8D1F\u8D23\u8FD0\u7EF4\
      \u6574 system \u57FA\u5EFA"
    role: devops
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_devops
    agent_type: claude
    model: Sonnet
    tmux_session: agent_system_devops
    cwd: /brain/groups/org/brain_system/agents/agent_system_devops
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_devops
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    desired_state: running
    status: active
    capabilities:
    - deployment
    - infrastructure
    - monitoring
    - troubleshooting
    tags:
    - '#devops'
    - '#ops'
    - '#infra'
  - name: agent_system_dev
    description: "\u5F00\u53D1\u5DE5\u7A0B\u5E08 - \u5B9E\u9645\u9879\u76EE\u4EE3\u7801\
      \u7F16\u5199"
    role: dev
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_dev
    agent_type: minimax
    cli_type: claude
    model: MiniMax-M2.5
    tmux_session: agent_system_dev
    cwd: /brain/groups/org/brain_system/agents/agent_system_dev
