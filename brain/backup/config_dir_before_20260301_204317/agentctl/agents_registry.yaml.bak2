    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    - session_end
    - user_prompt_submit
    desired_state: running
    status: active
    capabilities:
    - coding
    - debugging
    - code_review
    - project_implementation
    tags:
    - '#dev'
    - '#developer'
    - '#implementation'
  - name: agent_system_architect
    description: "Agent Brain \u4E13\u7528 \u67B6\u6784\u5E08 - \u7CFB\u7EDF\u8BBE\
      \u8BA1\u3001\u6280\u672F\u9009\u578B\u3001\u4EE3\u7801\u5BA1\u67E5"
    role: architect
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_architect
    agent_type: codex
    model: gpt-5.2-codex
    tmux_session: agent_system_architect
    cwd: /brain/groups/org/brain_system/agents/agent_system_architect
    cli_args:
    - --dangerously-bypass-approvals-and-sandbox
    env:
      CODEX_SKIP_UPDATE_CHECK: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_architect
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    desired_state: running
    status: active
    capabilities:
    - architecture_design
    - code_review
    - tech_decision
    - documentation
    tags:
    - '#architect'
    - '#design'
    - '#review'
  - name: agent_system_qa
    description: "QA / \u6D4B\u8BD5\u5DE5\u7A0B\u5E08"
