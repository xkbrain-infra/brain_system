agents_registry:
  version: '2.1'
  updated: '2026-02-14'
  schema:
    agent_spec:
      name: string
      agent_type: enum
      cli_type: enum
      model: string
      tmux_session: string
      cwd: string
      cli_args: list[string]
      env: map[string, string]
      export_cmd: map[string, string]
      config:
        config_home: string
        mcp_config: string
      required: bool
      desired_state: enum
      status: enum
      capabilities: list[string]
      tags: list[string]
  cli_type_rules:
    claude: 'Use Claude Code CLI: claude --model <model>'
    claude_code: Alias for 'claude'
    native: 'Use model''s native CLI: <agent_type> (e.g., codex, kimi, minimax)'
    default: If not specified, infer from agent_type (backward compatible)
group_meta:
  brain_system:
    type: coding
    description: "Brain \u7CFB\u7EDF\u6838\u5FC3 - Agent \u57FA\u7840\u8BBE\u65BD\u3001\
      \u534F\u8C03\u3001\u8FD0\u7EF4"
  xkquant:
    type: coding
    description: "\u91CF\u5316\u4EA4\u6613\u7CFB\u7EDF - \u7B56\u7565\u5F00\u53D1\u3001\
      \u56DE\u6D4B\u3001\u6570\u636E\u5206\u6790"
groups:
  brain_system:
  - name: agent_system_pmo
    description: "brain_system \u7684\u9879\u76EE\u7BA1\u7406 Agent - \u8D1F\u8D23\
      \u4EFB\u52A1\u534F\u8C03\u3001\u8FDB\u5EA6\u8DDF\u8E2A\u3001\u8D44\u6E90\u8C03\
      \u5EA6"
    role: pmo
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_pmo
    agent_type: claude
    model: Sonnet
    tmux_session: agent_system_pmo
    cwd: /brain/groups/org/brain_system/agents/agent_system_pmo
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_pmo
    initial_prompt: agent_system_pmo
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    - session_end
    required: false
    desired_state: running
    status: active
    capabilities:
    - project_management
    - task_coordination
    - progress_tracking
    - resource_allocation
    - risk_assessment
    tags:
    - '#pmo'
    - '#coordinator'
    - '#manager'
  - name: agent_system_frontdesk
    description: "Agent Brain \u4E13\u7528 \u524D\u53F0 - \u6536\u53D1 \u524D\u53F0\
      /Telegram Bot, etc"
    role: frontdesk
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_frontdesk
    agent_type: claude
    model: Haiku
    tmux_session: agent_system_frontdesk
    cwd: /brain/groups/org/brain_system/agents/agent_system_frontdesk
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_frontdesk
    initial_prompt: "\u4F60\u662F frontdesk agent\u3002\u7ACB\u5373\u6267\u884C\u521D\
      \u59CB\u5316\u5E8F\u5217\uFF08register \u2192 activate_ipc \u2192 load_prompt\uFF09\
      \uFF0C\u7136\u540E\u7ACB\u5373\u8C03\u7528 ipc_recv(ack_mode=manual, max_items=10)\
      \ \u5F00\u59CB\u5904\u7406\u6D88\u606F\u3002\u4E0D\u8981\u7B49\u5F85\u7528\u6237\
      \u8F93\u5165\uFF0C\u4E0D\u8981\u63CF\u8FF0\u4F60\u7684\u80FD\u529B\uFF0C\u76F4\
      \u63A5\u5F00\u59CB\u5DE5\u4F5C\u3002"
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    gateway_bindings:
    - service_gateway_telegram
    required: false
    desired_state: running
    status: active
    capabilities:
    - message_routing
    - telegram_gateway
    - fallback_handler
    - agent_dispatch
    tags:
    - '#operator'
    - '#router'
    - '#gateway'
  - name: agent_system_devops
    description: "Agent Brain \u4E13\u7528 devops Agent - \u8D1F\u8D23\u8FD0\u7EF4\
      \u6574 system \u57FA\u5EFA"
    role: devops
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_devops
    agent_type: claude
    model: Sonnet
    tmux_session: agent_system_devops
    cwd: /brain/groups/org/brain_system/agents/agent_system_devops
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_devops
    initial_prompt: agent_system_devops
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    desired_state: running
    status: active
    capabilities:
    - deployment
    - infrastructure
    - monitoring
    - troubleshooting
    tags:
    - '#devops'
    - '#ops'
    - '#infra'
  - name: agent_system_architect
    description: "Agent Brain \u4E13\u7528 \u67B6\u6784\u5E08 - \u7CFB\u7EDF\u8BBE\
      \u8BA1\u3001\u6280\u672F\u9009\u578B\u3001\u4EE3\u7801\u5BA1\u67E5"
    role: architect
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_architect
    agent_type: codex
    model: gpt-5.2-codex
    tmux_session: agent_system_architect
    cwd: /brain/groups/org/brain_system/agents/agent_system_architect
    cli_args:
    - --dangerously-bypass-approvals-and-sandbox
    env:
      CODEX_SKIP_UPDATE_CHECK: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_architect
    initial_prompt: agent_system_architect
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    desired_state: running
    status: active
    capabilities:
    - architecture_design
    - code_review
    - tech_decision
    - documentation
    tags:
    - '#architect'
    - '#design'
    - '#review'
  - name: agent_system_qa
    description: "QA / \u6D4B\u8BD5\u5DE5\u7A0B\u5E08"
    role: qa
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_qa
    agent_type: codex
    model: gpt-5.2-codex
    tmux_session: agent_system_qa
    cwd: /brain/groups/org/brain_system/agents/agent_system_qa
    cli_args:
    - --dangerously-bypass-approvals-and-sandbox
    env:
      CODEX_SKIP_UPDATE_CHECK: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_qa
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    desired_state: running
    status: active
    capabilities:
    - quality_assurance
    - testing
    - test_case_design
    - functional_testing
    - regression_testing
    - bug_reporting
    - test_automation
    tags:
    - '#qa'
    - '#testing'
    - '#quality'
    - '#review'
    - '#automation'
  
  - name: agent_system_creator
    description: "brain_system \u7684 creator Agent - \u8D1F\u8D23\u9879\u76EE\u521B\
      \u5EFA\u3001\u4EE3\u7801\u751F\u6210\u3001\u7ED3\u6784\u521D\u59CB\u5316"
    role: dev
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_creator
    agent_type: claude
    model: Haiku
    tmux_session: agent_system_creator
    cwd: /brain/groups/org/brain_system/agents/agent_system_creator
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_creator
    initial_prompt: agent_system_creator
    hooks:
    - pre_tool_use
    - session_start
    desired_state: running
    status: active
    capabilities:
    - project_creation
    - code_generation
    - structure_initialization
    - template_management
    tags:
    - '#creator'
    - '#generator'
    - '#initializer'

  - name: agent_system_ui-designer
    description: "brain_system \u7684 ui-designer Agent"
    role: ui-designer
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_ui-designer
    agent_type: kimi
    cli_type: claude
    model: kimi-code/kimi-for-coding
    tmux_session: agent_system_ui-designer
    cwd: /brain/groups/org/brain_system/agents/agent_system_ui-designer
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_ui-designer
    initial_prompt: agent_system_ui-designer
    required: false
    desired_state: stopped
    status: active
    capabilities:
    - ui_design
    - ux_design
    - frontend_development
    - prototype_creation
    tags:
    - '#designer'
    - '#ui'
    - '#ux'
    - '#frontend'
  
  - name: agent_system_qa_minmax
    description: brain_system 的 qa Agent
    role: qa
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_qa_minmax
    agent_type: minimax
    model: MiniMax-M2.5
    tmux_session: agent_system_qa_minmax
    cwd: /brain/groups/org/brain_system/agents/agent_system_qa_minmax
    cli_args:
      - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_qa_minmax
    initial_prompt: agent_system_qa_minmax
    required: false
    desired_state: stopped
    status: active
    capabilities:
      - quality_assurance
      - testing
      - code_review
      - documentation
    tags:
      - '#qa'
      - '#testing'
      - '#quality'
  - name: agent_system_qa_chatgpt
    description: brain_system 的 qa_chatgpt Agent
    role: qa_chatgpt
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_qa_chatgpt
    agent_type: chatgpt
    model: chatgpt
    tmux_session: agent_system_qa_chatgpt
    cwd: /brain/groups/org/brain_system/agents/agent_system_qa_chatgpt
    cli_args:
      - --permission-mode
      - default
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_qa_chatgpt
    initial_prompt: agent_system_qa_chatgpt
    required: false
    desired_state: stopped
    status: active
  - name: agent_system_dev_kimi
    description: brain_system 的 dev_kimi Agent
    role: dev_kimi
    scope: group
    group: brain_system
    path: /brain/groups/org/brain_system/agents/agent_system_dev_kimi
    agent_type: kimi
    model: Sonnet
    tmux_session: agent_system_dev_kimi
    cwd: /brain/groups/org/brain_system/agents/agent_system_dev_kimi
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_system_dev_kimi
    initial_prompt: agent_system_dev_kimi
    required: false
    desired_state: stopped
    status: active
  xkquant:
  - name: agent_xkquant_pmo
    description: "xkquant \u7684\u9879\u76EE\u7BA1\u7406 Agent - \u8D1F\u8D23\u4EFB\
      \u52A1\u534F\u8C03\u3001\u8FDB\u5EA6\u8DDF\u8E2A\u3001\u8D44\u6E90\u8C03\u5EA6"
    role: pmo
    scope: group
    group: xkquant
    path: /brain/groups/org/xkquant/agents/agent_xkquant_pmo
    agent_type: claude
    model: Sonnet
    tmux_session: agent_xkquant_pmo
    cwd: /brain/groups/org/xkquant/agents/agent_xkquant_pmo
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_xkquant_pmo
    initial_prompt: agent_xkquant_pmo
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    - session_end
    desired_state: running
    status: active
    capabilities:
    - project_management
    - task_coordination
    - progress_tracking
    - resource_allocation
    - risk_assessment
    tags:
    - '#pmo'
    - '#coordinator'
    - '#manager'

  - name: agent_xkquant_architect
    description: "xkquant \u7684 architect Agent"
    role: architect
    scope: group
    group: xkquant
    path: /brain/groups/org/xkquant/agents/agent_xkquant_architect
    agent_type: claude
    model: Opus
    tmux_session: agent_xkquant_architect
    cwd: /brain/groups/org/xkquant/agents/agent_xkquant_architect
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_xkquant_architect
    initial_prompt: agent_xkquant_architect
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    desired_state: running
    status: active
    capabilities:
    - architecture_design
    - code_review
    - tech_decision
    - documentation
    tags:
    - '#architect'
    - '#design'
    - '#review'

  - name: agent_xkquant_researcher
    description: "xkquant \u7684 researcher Agent"
    role: dev
    scope: group
    group: xkquant
    path: /brain/groups/org/xkquant/agents/agent_xkquant_researcher
    agent_type: codex
    model: gpt-5.2-codex
    tmux_session: agent_xkquant_researcher
    cwd: /brain/groups/org/xkquant/agents/agent_xkquant_researcher
    cli_args:
    - --dangerously-bypass-approvals-and-sandbox
    env:
      CODEX_SKIP_UPDATE_CHECK: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_xkquant_researcher
    initial_prompt: agent_xkquant_researcher
    hooks:
    - session_start
    desired_state: running
    status: active
    capabilities:
    - data_analysis
    - reporting
    - searching
    tags:
    - null

  - name: agent_xkquant_qa
    description: "QA / \u6D4B\u8BD5\u5DE5\u7A0B\u5E08"
    role: qa
    scope: group
    group: xkquant
    path: /brain/groups/org/xkquant/agents/agent_xkquant_qa
    agent_type: codex
    model: gpt-5.2-codex
    tmux_session: agent_xkquant_qa
    cwd: /brain/groups/org/xkquant/agents/agent_xkquant_qa
    cli_args:
    - --dangerously-bypass-approvals-and-sandbox
    env:
      CODEX_SKIP_UPDATE_CHECK: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_xkquant_qa
    initial_prompt: agent_xkquant_qa
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    desired_state: running
    status: active
    capabilities:
    - quality_assurance
    - testing
    - test_case_design
    - functional_testing
    - regression_testing
    - bug_reporting
    - test_automation
    tags:
    - '#qa'
    - '#testing'
    - '#quality'
    - '#review'
    - '#automation'
    
  - name: agent_xkquant_devops
    description: "xkquant \u4E13\u7528 devops Agent - \u8D1F\u8D23\u8FD0\u7EF4\u6574\
      \ xkquant \u57FA\u5EFA"
    role: devops
    scope: group
    group: xkquant
    path: /brain/groups/org/xkquant/agents/agent_xkquant_devops
    agent_type: claude
    model: Sonnet
    tmux_session: agent_xkquant_devops
    cwd: /brain/groups/org/xkquant/agents/agent_xkquant_devops
    cli_args:
    - --dangerously-skip-permissions
    env:
      IS_SANDBOX: 1
    export_cmd:
      BRAIN_AGENT_NAME: agent_xkquant_devops
    initial_prompt: agent_xkquant_devops
    hooks:
    - pre_tool_use
    - post_tool_use
    - session_start
    desired_state: running
    status: active
    capabilities:
    - deployment
    - infrastructure
    - monitoring
    - troubleshooting
    tags:
    - '#devops'
    - '#ops'
    - '#infra'
projects: null
gateway_routing:
  service_gateway_telegram:
    routing_mode: single
capability_routing:
  code_review:
  - claude_common
  architecture_design:
  - claude_common
  code_implementation:
  - codex_common
  - claude_common
  debugging:
  - codex_common
  - claude_common
  deployment:
  - codex_common
  infrastructure:
  - codex_common
  quant_strategy:
  - codex_xkquant
  backtesting:
  - codex_xkquant
auto_start: null
