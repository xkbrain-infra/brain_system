#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="/brain/infrastructure/service/brain_gateway"
CONFIG_FILE="${ROOT_DIR}/config/brain_gateway.json"
BIN_LINK="${ROOT_DIR}/bin/current"
BACKUP_DIR="${ROOT_DIR}/backups"
SESSION_NAME="${BRAIN_GATEWAY_TMUX_SESSION:-brain_gateway}"
HEALTH_URL_DEFAULT="http://127.0.0.1:8200/health"

usage() {
  cat <<'EOF'
brain_gatewayctl - release switch + rollback guard for brain_gateway

Usage:
  brain_gatewayctl snapshot [--label LABEL]
  brain_gatewayctl list
  brain_gatewayctl status [--health-url URL]
  brain_gatewayctl promote --release RELEASE [--health-url URL] [--timeout SEC]
  brain_gatewayctl rollback [--snapshot SNAPSHOT_ID] [--health-url URL] [--timeout SEC]

Examples:
  brain_gatewayctl snapshot --label before-fusion
  brain_gatewayctl promote --release v0.1.1
  brain_gatewayctl rollback
EOF
}

now_utc() {
  date -u +"%Y%m%dT%H%M%SZ"
}

require_cmd() {
  local cmd="$1"
  command -v "${cmd}" >/dev/null 2>&1 || {
    echo "ERROR: missing command: ${cmd}" >&2
    exit 1
  }
}

current_release_path() {
  if [[ -L "${BIN_LINK}" ]]; then
    local target
    target="$(readlink "${BIN_LINK}")"
    # bin/current points to ../releases/<ver>/bin
    python3 - <<PY
import os
print(os.path.normpath(os.path.join("${ROOT_DIR}/bin", "${target}")))
PY
  else
    echo ""
  fi
}

health_check() {
  local url="$1"
  local timeout_s="$2"
  python3 - <<PY
import json
import sys
import time
import urllib.request
import urllib.error

url = "${url}"
deadline = time.time() + ${timeout_s}
last_err = ""
while time.time() < deadline:
    try:
        with urllib.request.urlopen(url, timeout=2) as r:
            body = r.read().decode("utf-8", "ignore")
            if r.status == 200:
                try:
                    data = json.loads(body)
                    if str(data.get("status", "")).lower() in {"ok", "healthy"}:
                        print("ok")
                        sys.exit(0)
                except Exception:
                    pass
                if body:
                    print("ok")
                    sys.exit(0)
    except Exception as e:
        last_err = str(e)
    time.sleep(1)
print(last_err)
sys.exit(1)
PY
}

ensure_dirs() {
  mkdir -p "${BACKUP_DIR}"
}

snapshot() {
  local label="$1"
  ensure_dirs
  local ts
  ts="$(now_utc)"
  local id="${ts}"
  if [[ -n "${label}" ]]; then
    id="${ts}_${label}"
  fi
  local dir="${BACKUP_DIR}/${id}"
  mkdir -p "${dir}"

  local rel
  rel="$(current_release_path)"
  [[ -f "${CONFIG_FILE}" ]] && cp "${CONFIG_FILE}" "${dir}/brain_gateway.json"

  python3 - <<PY
import json
import os
meta = {
  "snapshot_id": "${id}",
  "created_at_utc": "${ts}",
  "release_path": "${rel}",
  "config_file": "${CONFIG_FILE}",
  "tmux_session": "${SESSION_NAME}",
}
with open("${dir}/meta.json", "w", encoding="utf-8") as f:
    json.dump(meta, f, ensure_ascii=False, indent=2)
PY
  echo "${id}"
}

list_snapshots() {
  ensure_dirs
  ls -1 "${BACKUP_DIR}" | sort -r
}

restart_gateway() {
  local cmd
  cmd="cd ${ROOT_DIR} && ${BIN_LINK}/brain_gateway --config ${CONFIG_FILE}"
  if tmux has-session -t "${SESSION_NAME}" 2>/dev/null; then
    tmux kill-session -t "${SESSION_NAME}"
  fi
  tmux new-session -d -s "${SESSION_NAME}" "${cmd}"
}

restore_snapshot() {
  local snapshot_id="$1"
  local dir="${BACKUP_DIR}/${snapshot_id}"
  [[ -d "${dir}" ]] || {
    echo "ERROR: snapshot not found: ${snapshot_id}" >&2
    exit 1
  }
  local release_path
  release_path="$(python3 - <<PY
import json
from pathlib import Path
p = Path("${dir}/meta.json")
if not p.exists():
  print("")
else:
  print((json.loads(p.read_text(encoding="utf-8"))).get("release_path", ""))
PY
)"
  if [[ -n "${release_path}" ]]; then
    local rel_link
    rel_link="$(python3 - <<PY
import os
print(os.path.relpath("${release_path}", "${ROOT_DIR}/bin"))
PY
)"
    ln -sfn "${rel_link}" "${BIN_LINK}"
  fi
  if [[ -f "${dir}/brain_gateway.json" ]]; then
    cp "${dir}/brain_gateway.json" "${CONFIG_FILE}"
  fi
}

status() {
  local health_url="$1"
  local rel
  rel="$(current_release_path)"
  echo "session=${SESSION_NAME}"
  echo "release_path=${rel:-<none>}"
  if tmux has-session -t "${SESSION_NAME}" 2>/dev/null; then
    echo "tmux=running"
  else
    echo "tmux=stopped"
  fi
  if health_check "${health_url}" 2 >/dev/null 2>&1; then
    echo "health=ok ${health_url}"
  else
    echo "health=down ${health_url}"
  fi
}

promote() {
  local release="$1"
  local health_url="$2"
  local timeout_s="$3"
  local target_dir="${ROOT_DIR}/releases/${release}/bin"
  local target_bin="${target_dir}/brain_gateway"
  [[ -x "${target_bin}" ]] || {
    echo "ERROR: release binary not found: ${target_bin}" >&2
    exit 1
  }

  local snap_id
  snap_id="$(snapshot "auto_before_promote_${release}")"
  echo "snapshot=${snap_id}"

  local rel_link
  rel_link="$(python3 - <<PY
import os
print(os.path.relpath("${target_dir}", "${ROOT_DIR}/bin"))
PY
)"
  ln -sfn "${rel_link}" "${BIN_LINK}"
  restart_gateway

  if health_check "${health_url}" "${timeout_s}" >/dev/null 2>&1; then
    echo "promote_ok release=${release}"
    return 0
  fi

  echo "promote_failed release=${release}, rollback=${snap_id}" >&2
  restore_snapshot "${snap_id}"
  restart_gateway
  if health_check "${health_url}" "${timeout_s}" >/dev/null 2>&1; then
    echo "rollback_ok snapshot=${snap_id}"
  else
    echo "rollback_failed snapshot=${snap_id}" >&2
  fi
  exit 1
}

rollback() {
  local snapshot_id="$1"
  local health_url="$2"
  local timeout_s="$3"

  if [[ -z "${snapshot_id}" ]]; then
    snapshot_id="$(list_snapshots | head -n 1 || true)"
  fi
  [[ -n "${snapshot_id}" ]] || {
    echo "ERROR: no snapshot available" >&2
    exit 1
  }

  restore_snapshot "${snapshot_id}"
  restart_gateway
  if health_check "${health_url}" "${timeout_s}" >/dev/null 2>&1; then
    echo "rollback_ok snapshot=${snapshot_id}"
  else
    echo "rollback_failed snapshot=${snapshot_id}" >&2
    exit 1
  fi
}

main() {
  require_cmd python3
  require_cmd tmux
  mkdir -p "${ROOT_DIR}/bin"

  local cmd="${1:-}"
  [[ -n "${cmd}" ]] || {
    usage
    exit 1
  }
  shift || true

  case "${cmd}" in
    snapshot)
      local label=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --label) label="${2:-}"; shift 2 ;;
          *) echo "ERROR: unknown arg: $1" >&2; exit 1 ;;
        esac
      done
      snapshot "${label}"
      ;;
    list)
      list_snapshots
      ;;
    status)
      local health_url="${HEALTH_URL_DEFAULT}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --health-url) health_url="${2:-}"; shift 2 ;;
          *) echo "ERROR: unknown arg: $1" >&2; exit 1 ;;
        esac
      done
      status "${health_url}"
      ;;
    promote)
      local release=""
      local health_url="${HEALTH_URL_DEFAULT}"
      local timeout_s="20"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --release) release="${2:-}"; shift 2 ;;
          --health-url) health_url="${2:-}"; shift 2 ;;
          --timeout) timeout_s="${2:-}"; shift 2 ;;
          *) echo "ERROR: unknown arg: $1" >&2; exit 1 ;;
        esac
      done
      [[ -n "${release}" ]] || {
        echo "ERROR: --release is required" >&2
        exit 1
      }
      promote "${release}" "${health_url}" "${timeout_s}"
      ;;
    rollback)
      local snapshot_id=""
      local health_url="${HEALTH_URL_DEFAULT}"
      local timeout_s="20"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --snapshot) snapshot_id="${2:-}"; shift 2 ;;
          --health-url) health_url="${2:-}"; shift 2 ;;
          --timeout) timeout_s="${2:-}"; shift 2 ;;
          *) echo "ERROR: unknown arg: $1" >&2; exit 1 ;;
        esac
      done
      rollback "${snapshot_id}" "${health_url}" "${timeout_s}"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      echo "ERROR: unknown command: ${cmd}" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
