#!/usr/bin/env python3
"""GitHub Copilot OAuth 认证 - 完全独立实现 (Device Flow)."""
import asyncio
import json
import os
import sys
import time
from pathlib import Path

import httpx


async def main():
    print("🔐 GitHub Copilot OAuth 认证")
    print("=" * 50)

    # GitHub OAuth App (copilot-api 使用的)
    CLIENT_ID = "Iv1.b507a08c87ecfe98"
    AUTH_URL = "https://github.com/login/device/code"
    TOKEN_URL = "https://github.com/login/oauth/access_token"

    # 1. 获取设备码
    print("\n[1] 获取授权码...")
    async with httpx.AsyncClient(timeout=30.0) as client:
        resp = await client.post(
            AUTH_URL,
            data={"client_id": CLIENT_ID, "scope": "read:user"},
            headers={"Accept": "application/json"},
        )

    if resp.status_code != 200:
        print(f"❌ 获取设备码失败: {resp.status_code}")
        print(resp.text)
        return 1

    data = resp.json()
    device_code = data.get("device_code")
    user_code = data.get("user_code")
    verification_uri = data.get("verification_uri")
    interval = data.get("interval", 5)

    print(f"\n[2] 请在浏览器中打开:")
    print(f"    {verification_uri}")
    print(f"\n[3] 输入授权码: {user_code}")
    print(f"\n[4] 等待授权完成...")
    print("    (批准后会自动继续)")

    # 2. 轮询 token
    start_time = time.time()
    timeout = 300

    while time.time() - start_time < timeout:
        await asyncio.sleep(interval)

        async with httpx.AsyncClient(timeout=30.0) as client:
            resp = await client.post(
                TOKEN_URL,
                data={
                    "client_id": CLIENT_ID,
                    "device_code": device_code,
                    "grant_type": "urn:ietf:params:oauth:grant-type:device_code",
                },
                headers={"Accept": "application/json"},
            )

        if resp.status_code != 200:
            error_data = resp.json()
            error = error_data.get("error", "")

            if error == "authorization_pending":
                print(".", end="", flush=True)
                continue
            elif error == "slow_down":
                interval += 1
                print(".", end="", flush=True)
                continue
            elif error == "expired_token":
                print("\n❌ 授权码已过期，请重新运行")
                return 1
            elif error == "access_denied":
                print("\n❌ 授权被拒绝")
                return 1
            else:
                print(f"\n❌ 错误: {error}")
                return 1

        # 成功!
        token_data = resp.json()
        access_token = token_data.get("access_token")

        if access_token:
            print("\n\n✅ 授权成功!")

            # 保存 token
            token_dir = Path("~/.local/share/brain_agent_proxy/tokens").expanduser()
            token_dir.mkdir(parents=True, exist_ok=True)
            token_file = token_dir / "github_oauth.json"

            json.dump({
                "github_token": access_token,
                "token_type": token_data.get("token_type", "bearer"),
                "expires_at": int(time.time()) + 3600,
            }, open(token_file, "w"))
            os.chmod(token_file, 0o600)

            print(f"   Token 保存到: {token_file}")
            print(f"   Token: {access_token[:20]}...")

            # 测试获取 Copilot token
            print("\n[5] 测试获取 Copilot token...")
            try:
                async with httpx.AsyncClient(timeout=30.0) as client:
                    resp = await client.get(
                        "https://api.github.com/copilot_internal/v2/token",
                        headers={
                            "Authorization": f"token {access_token}",
                            "Accept": "application/json",
                            "content-type": "application/json",
                            "editor-version": "vscode/1.95.3",
                            "editor-plugin-version": "copilot-chat/0.26.7",
                            "user-agent": "GitHubCopilotChat/0.26.7",
                            "x-github-api-version": "2022-11-28",
                        },
                    )

                if resp.status_code == 200:
                    copilot_data = resp.json()
                    copilot_token = copilot_data.get("token")
                    if copilot_token:
                        copilot_file = token_dir / "copilot.json"
                        json.dump({
                            "access_token": copilot_token,
                            "expires_at": copilot_data.get("expires_at", int(time.time()) + 3600),
                            "github_token": access_token,
                        }, open(copilot_file, "w"))
                        os.chmod(copilot_file, 0o600)
                        print(f"   ✅ Copilot token 获取成功!")
                        print(f"   保存到: {copilot_file}")
                    else:
                        print(f"   ⚠️ Copilot token 响应: {copilot_data}")
                else:
                    # Fallback: many environments can call api.githubcopilot.com directly with GitHub OAuth token.
                    copilot_file = token_dir / "copilot.json"
                    json.dump({
                        "access_token": access_token,
                        "expires_at": int(time.time()) + 3600,
                        "github_token": access_token,
                        "mode": "direct_github_oauth_fallback",
                    }, open(copilot_file, "w"))
                    os.chmod(copilot_file, 0o600)
                    print(f"   ✅ Copilot 直连模式可用（v2/token={resp.status_code}）")
                    print(f"   已保存: {copilot_file}")
            except Exception as e:
                copilot_file = token_dir / "copilot.json"
                json.dump({
                    "access_token": access_token,
                    "expires_at": int(time.time()) + 3600,
                    "github_token": access_token,
                    "mode": "direct_github_oauth_fallback",
                }, open(copilot_file, "w"))
                os.chmod(copilot_file, 0o600)
                print(f"   ✅ Copilot 直连模式可用（network fallback）")
                print(f"   已保存: {copilot_file}")

            return 0

    print("\n❌ 超时，请重新运行")
    return 1


if __name__ == "__main__":
    sys.exit(asyncio.run(main()))
