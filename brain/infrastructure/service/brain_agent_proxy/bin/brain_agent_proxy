#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
APP_DIR="$SCRIPT_DIR/.."
VENV_PYTHON="$APP_DIR/.venv/bin/python"
SECRETS_ENV_CANDIDATES=(
    "/brain/secrets/system/agents/llm_tokens.env"
    "/xkagent_infra/brain/secrets/system/agents/llm_tokens.env"
)
RUNTIME_ENV_FILE="/brain/runtime/config/.env"

# Default values
DEFAULT_PORT="${BRAIN_AGENT_PROXY_DEFAULT_PORT:-8210}"
DEFAULT_HOST="0.0.0.0"
DEFAULT_LOG_LEVEL="info"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/brain_agent_proxy"

log() {
    printf "[brain-agent-proxy] %s\n" "$*"
}

pid_file_for_port() {
    local port="$1"
    echo "$RUNTIME_DIR/proxy_${port}.pid"
}

log_file_for_port() {
    local port="$1"
    echo "$RUNTIME_DIR/proxy_${port}.log"
}

usage() {
    cat <<'EOF'
Usage:
    brain_agent_proxy start [--port N] [--host HOST] [--log-level LEVEL]
    brain_agent_proxy run [--port N] [--host HOST] [--log-level LEVEL]
    brain_agent_proxy stop
    brain_agent_proxy restart [--port N]
    brain_agent_proxy status
    brain_agent_proxy health [--port N]

Examples:
    brain_agent_proxy start --port 8210
    brain_agent_proxy start --port 8210 --log-level DEBUG
EOF
}

get_pid() {
    local port="$1"
    local pid_file
    pid_file="$(pid_file_for_port "$port")"
    if [[ -f "$pid_file" ]]; then
        local pid
        pid="$(cat "$pid_file" 2>/dev/null || true)"
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            echo "$pid"
            return 0
        fi
    fi
    if command -v lsof >/dev/null 2>&1; then
        lsof -ti ":$port" 2>/dev/null || true
    elif command -v ss >/dev/null 2>&1; then
        ss -tlnp 2>/dev/null | grep ":$port " | grep -oP 'pid=\K[0-9]+' || true
    elif command -v pgrep >/dev/null 2>&1; then
        pgrep -f "uvicorn src.main:app --host .* --port $port" | head -n 1 || true
    fi
}

resolve_python_bin() {
    if [[ -x "$VENV_PYTHON" ]]; then
        echo "$VENV_PYTHON"
        return 0
    fi
    echo "python3"
}

resolve_env_file() {
    local candidate=""
    for candidate in "${SECRETS_ENV_CANDIDATES[@]}"; do
        if [[ -f "$candidate" ]]; then
            echo "$candidate"
            return 0
        fi
    done
    if [[ -f "$RUNTIME_ENV_FILE" ]]; then
        echo "$RUNTIME_ENV_FILE"
        return 0
    fi
    return 1
}

is_running() {
    local port="$1"
    local pid
    pid=$(get_pid "$port")
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        return 0
    fi
    return 1
}

start_proxy() {
    local port="${1:-$DEFAULT_PORT}"
    local host="${2:-$DEFAULT_HOST}"
    local log_level="${3:-$DEFAULT_LOG_LEVEL}"
    local pid_file
    local log_file
    pid_file="$(pid_file_for_port "$port")"
    log_file="$(log_file_for_port "$port")"

    if is_running "$port"; then
        log "Already running on port $port"
        return 0
    fi

    log "Starting brain_agent_proxy on $host:$port"

    local python_bin
    local env_file=""
    local shell_cmd=""
    python_bin="$(resolve_python_bin)"
    env_file="$(resolve_env_file || true)"

    cd "$APP_DIR"
    mkdir -p "$RUNTIME_DIR"
    if [[ -n "$env_file" ]]; then
        shell_cmd="set -a && source '$env_file' && set +a && "
    fi
    shell_cmd+="export PYTHONPATH='$APP_DIR' && exec '$python_bin' -m uvicorn src.main:app --host '$host' --port '$port' --log-level '$log_level'"
    nohup bash -lc "$shell_cmd" >"$log_file" 2>&1 < /dev/null &
    echo $! > "$pid_file"

    # Wait for startup
    local i
    for i in $(seq 1 30); do
        if curl -fsS "http://127.0.0.1:$port/health" >/dev/null 2>&1; then
            log "Started on $host:$port"
            return 0
        fi
        sleep 1
    done

    log "Failed to start (log: $log_file)"
    return 1
}

run_proxy() {
    local port="${1:-$DEFAULT_PORT}"
    local host="${2:-$DEFAULT_HOST}"
    local log_level="${3:-$DEFAULT_LOG_LEVEL}"
    local python_bin
    local env_file=""

    python_bin="$(resolve_python_bin)"
    env_file="$(resolve_env_file || true)"

    cd "$APP_DIR"
    if [[ -n "$env_file" ]]; then
        set -a
        # shellcheck disable=SC1090
        source "$env_file"
        set +a
    fi
    export PYTHONPATH="$APP_DIR"
    exec "$python_bin" -m uvicorn src.main:app --host "$host" --port "$port" --log-level "$log_level"
}

stop_proxy() {
    local port="${1:-$DEFAULT_PORT}"
    local pid
    local pid_file
    pid_file="$(pid_file_for_port "$port")"
    pid=$(get_pid "$port")

    if [[ -z "$pid" ]]; then
        log "Not running on port $port"
        return 0
    fi

    log "Stopping brain_agent_proxy (pid=$pid)"
    kill "$pid" 2>/dev/null || true
    sleep 1

    if kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null || true
    fi
    rm -f "$pid_file"

    log "Stopped"
}

restart_proxy() {
    local port="${1:-$DEFAULT_PORT}"
    stop_proxy "$port"
    sleep 1
    start_proxy "$port"
}

status_proxy() {
    local port="${1:-$DEFAULT_PORT}"

    if is_running "$port"; then
        local pid
        pid=$(get_pid "$port")
        log "Running on port $port (pid=$pid)"
        return 0
    else
        log "Not running on port $port"
        return 1
    fi
}

health_proxy() {
    local port="${1:-$DEFAULT_PORT}"

    if curl -fsS "http://127.0.0.1:$port/health"; then
        return 0
    else
        log "Unhealthy or not running"
        return 1
    fi
}

# Parse command
CMD="${1:-}"
shift || true

case "$CMD" in
    start)
        PORT=""
        HOST="$DEFAULT_HOST"
        LOG_LEVEL="$DEFAULT_LOG_LEVEL"

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --port)
                    PORT="$2"
                    shift 2
                    ;;
                --host)
                    HOST="$2"
                    shift 2
                    ;;
                --log-level)
                    LOG_LEVEL="$2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done

        PORT="${PORT:-$DEFAULT_PORT}"
        start_proxy "$PORT" "$HOST" "$LOG_LEVEL"
        ;;
    run)
        PORT=""
        HOST="$DEFAULT_HOST"
        LOG_LEVEL="$DEFAULT_LOG_LEVEL"

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --port)
                    PORT="$2"
                    shift 2
                    ;;
                --host)
                    HOST="$2"
                    shift 2
                    ;;
                --log-level)
                    LOG_LEVEL="$2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done

        PORT="${PORT:-$DEFAULT_PORT}"
        run_proxy "$PORT" "$HOST" "$LOG_LEVEL"
        ;;
    stop)
        PORT="${1:-${DEFAULT_PORT}}"
        stop_proxy "$PORT"
        ;;
    restart)
        PORT=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --port)
                    PORT="$2"
                    shift 2
                    ;;
                *)
                    if [[ -z "$PORT" ]]; then
                        PORT="$1"
                    fi
                    shift
                    ;;
            esac
        done
        PORT="${PORT:-${DEFAULT_PORT}}"
        restart_proxy "$PORT"
        ;;
    status)
        PORT="${1:-${DEFAULT_PORT}}"
        status_proxy "$PORT"
        ;;
    health)
        PORT="${1:-${DEFAULT_PORT}}"
        health_proxy "$PORT"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        usage
        ;;
esac
