#!/usr/bin/env python3
"""AgentCTL - Unified agent control tool.

Modes:
- CLI: Direct tmux agent operations (list, start, stop, restart)
- Service: IPC daemon service (serve)
"""

from __future__ import annotations

import argparse
import asyncio
import json
import os
import shutil
import socket
import subprocess
import sys
import yaml
from dataclasses import dataclass
from pathlib import Path
from typing import Any

# Add service directory to Python path
SERVICE_DIR = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(SERVICE_DIR))


# ============================================================
# CLI Mode - Direct tmux operations
# ============================================================

@dataclass(frozen=True)
class AgentSpec:
    name: str
    tmux_session: str
    start_cmd: str | None
    cwd: str | None
    status: str
    agent_type: str = "claude"
    role: str = ""
    group: str = ""
    description: str = ""
    raw_spec: dict = None  # type: ignore[assignment]


def _tmux(*args: str, timeout_s: float = 8.0) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["tmux", *args],
        capture_output=True,
        text=True,
        timeout=timeout_s,
        check=False,
    )


def _has_session(name: str) -> bool:
    p = _tmux("has-session", "-t", name)
    return p.returncode == 0


def _kill_session(name: str, *, apply: bool) -> None:
    if not _has_session(name):
        print(f"- {name}: not running")
        return
    if not apply:
        print(f"- {name}: would stop (tmux kill-session -t {name})")
        return
    p = _tmux("kill-session", "-t", name)
    if p.returncode != 0:
        raise RuntimeError((p.stderr or p.stdout or "").strip() or "tmux kill-session failed")
    print(f"- {name}: stopped")


# ============================================================
# Secrets & env mapping
# ============================================================

_SECRETS_FILE = Path("/xkagent_infra/brain/secrets/system/agents/llm_tokens.env")

# agent_type → { target_env_var: source_env_var_in_secrets }
# When cli_type=claude, Claude Code needs ANTHROPIC_API_KEY/ANTHROPIC_BASE_URL
_AGENT_TYPE_ENV_MAP: dict[str, dict[str, str]] = {
    "codex": {
        "OPENAI_API_KEY": "OPENAI_API_KEY",
        "OPENAI_BASE_URL": "OPENAI_API_BASE",
    },
    "kimi": {
        "ANTHROPIC_API_KEY": "KIMI_API_KEY",
        "ANTHROPIC_AUTH_TOKEN": "KIMI_API_KEY",
        "ANTHROPIC_BASE_URL": "KIMI_API_BASE",
    },
    "minimax": {
        "ANTHROPIC_API_KEY": "MINIMAX_API_KEY",
        "ANTHROPIC_AUTH_TOKEN": "MINIMAX_API_KEY",
        "ANTHROPIC_BASE_URL": "MINIMAX_API_BASE",
    },
    "chatgpt": {
        "ANTHROPIC_API_KEY": "LITELLM_MASTER_KEY",
        "ANTHROPIC_AUTH_TOKEN": "LITELLM_MASTER_KEY",
        "ANTHROPIC_BASE_URL": "LITELLM_ANTHROPIC_BASE",
    },
    "gemini": {},
    # QWEN (阿里巴巴千问 - DashScope)
    # 支持模型: qwen3.5-plus, qwen3-max-2026-01-23, qwen3-coder-next, qwen3-coder-plus, glm-4.7, kimi-k2.5
    "qwen": {
        "ANTHROPIC_AUTH_TOKEN": "QWEN_API_KEY",
        "ANTHROPIC_BASE_URL": "QWEN_API_BASE",
    },
    # Bytedance (字节方舟)
    # 支持模型: doubao-seed-2.0-code, doubao-seed-code, glm-4.7, deepseek-v3.2, kimi-k2-thinking, kimi-k2.5
    "bytedance": {
        "ANTHROPIC_AUTH_TOKEN": "BYTEDANCE_API_KEY",
        "ANTHROPIC_BASE_URL": "BYTEDANCE_API_BASE",
    },
}


def _load_secrets() -> dict[str, str]:
    """Load key=value pairs from secrets env file."""
    if not _SECRETS_FILE.exists():
        return {}
    result: dict[str, str] = {}
    for line in _SECRETS_FILE.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" in line:
            key, _, val = line.partition("=")
            result[key.strip()] = val.strip()
    return result


def _build_env_inline(agent_type: str) -> str:
    """Build inline env prefix for non-claude agent_types (e.g. 'VAR1=val1 VAR2=val2')."""
    mapping = _AGENT_TYPE_ENV_MAP.get(agent_type)
    if not mapping:
        return ""
    secrets = _load_secrets()
    parts: list[str] = []
    for target_var, source_var in mapping.items():
        val = secrets.get(source_var, "")
        if val:
            parts.append(f"{target_var}={val}")
    return " ".join(parts)


def _generate_configs(spec: AgentSpec, *, force_claude_md: bool = False) -> None:
    """Generate config files for an agent before starting."""
    from services.config_generator import generate_all_configs

    if not spec.raw_spec:
        print(f"  {spec.name}: skip config gen (no raw_spec)")
        return

    result = generate_all_configs(spec.raw_spec, force_claude_md=force_claude_md)
    if result.get("mcp_config"):
        mcp_file = ".codex/config.toml" if spec.agent_type == "codex" else ".mcp.json"
        print(f"  {spec.name}: generated {mcp_file}")
    if result.get("claude_md"):
        print(f"  {spec.name}: generated {result['claude_md']}")
    elif result.get("claude_md") is None and spec.role:
        md_name = "AGENTS.md" if spec.agent_type == "codex" else "CLAUDE.md"
        print(f"  {spec.name}: {md_name} exists (use --force to overwrite)")


def _start_session(spec: AgentSpec, *, apply: bool, config_gen: bool = True, force_claude_md: bool = False) -> None:
    if _has_session(spec.tmux_session):
        print(f"- {spec.name}: already running ({spec.tmux_session})")
        return
    if not spec.start_cmd:
        raise RuntimeError(f"{spec.name}: missing start_cmd in agents_registry.yaml")
    if not apply:
        cwd = spec.cwd or "/xkagent_infra/brain"
        print(f"- {spec.name}: would start (tmux new-session -d -s {spec.tmux_session} -c {cwd} {spec.start_cmd})")
        return

    # Generate config files before starting
    if config_gen:
        _generate_configs(spec, force_claude_md=force_claude_md)

    cmd = ["new-session", "-d", "-s", spec.tmux_session]
    if spec.cwd:
        cmd += ["-c", spec.cwd]

    # tmux session is an isolated shell — exports here don't pollute other sessions
    shell_parts: list[str] = [
        "unset CLAUDECODE",  # Prevent nested Claude Code session detection
        f"export TMUX_SESSION={spec.tmux_session}",
        "export TMUX_PANE=$(tmux display-message -p '#{pane_id}' 2>/dev/null)",
    ]
    if spec.agent_type == "codex" and spec.cwd:
        shell_parts.append(f"export CODEX_HOME={spec.cwd}/.codex")
    elif spec.agent_type == "kimi" and spec.cwd:
        shell_parts.append(f"export KIMI_HOME={spec.cwd}/.kimi")

    # Inject secrets mapping for non-claude agent types (scoped to this tmux session)
    mapping = _AGENT_TYPE_ENV_MAP.get(spec.agent_type)
    if mapping:
        secrets = _load_secrets()
        for target_var, source_var in mapping.items():
            val = secrets.get(source_var, "")
            if val:
                shell_parts.append(f"export {target_var}={val}")

    shell_parts.append(spec.start_cmd)

    cmd += [" && ".join(shell_parts)]
    p = _tmux(*cmd, timeout_s=12.0)
    if p.returncode != 0:
        raise RuntimeError((p.stderr or p.stdout or "").strip() or "tmux new-session failed")
    print(f"- {spec.name}: started ({spec.tmux_session})")


def _list_sessions() -> set[str]:
    p = _tmux("list-sessions", "-F", "#{session_name}", timeout_s=8.0)
    if p.returncode != 0:
        return set()
    return {line.strip() for line in (p.stdout or "").splitlines() if line.strip()}


def _load_spec(config_dir: Path) -> dict[str, AgentSpec]:
    from config.loader import YAMLConfigLoader

    loader = YAMLConfigLoader(config_dir=config_dir)
    cfg = loader.get_agents_registry()

    # 从 groups 下收集所有 agents (preserve group_name context)
    groups = cfg.get("groups", {}) if isinstance(cfg, dict) else {}
    all_agents: list[tuple[str, dict]] = []
    for group_name, group_agents in groups.items():
        if isinstance(group_agents, list):
            for ag in group_agents:
                if isinstance(ag, dict):
                    all_agents.append((group_name, ag))

    out: dict[str, AgentSpec] = {}
    for group_name, a in all_agents:
        if not isinstance(a, dict):
            continue
        name = str(a.get("name") or "").strip()
        tmux_session = str(a.get("tmux_session") or "").strip()
        if not name or not tmux_session:
            continue

        # 构建 start_cmd
        agent_type = str(a.get("agent_type") or "claude").strip().lower()
        cli_type = str(a.get("agent_cli") or a.get("cli_type") or "").strip().lower()
        cli_args = a.get("cli_args", [])
        cwd = str(a.get("cwd") or "").strip() or None
        export_cmd = a.get("export_cmd", {})

        # 导出环境变量
        exports = []
        for key, value in export_cmd.items():
            exports.append(f"export {key}={value}")

        # 构建完整命令
        # cli_type 优先级最高，明确指定使用哪个 CLI
        if cli_type in ("claude", "claude_code"):
            # 使用 Claude Code CLI
            cmd = "claude"
            use_claude_cli = True
        elif cli_type == "native":
            # 使用模型原生 CLI
            cmd = agent_type
            use_claude_cli = False
        else:
            # 向后兼容：如果没有指定 cli_type，根据 agent_type 推断
            if agent_type == "codex":
                cmd = "codex"
                use_claude_cli = False
            elif agent_type in ("claude", "kimi", "minimax", "chatgpt"):
                cmd = "claude"
                use_claude_cli = True
            else:
                cmd = agent_type
                use_claude_cli = False

        cmd_parts = [cmd]

        # 添加 --model 参数（仅当显式指定时）
        model = str(a.get("agent_model") or a.get("model") or "").strip()
        if use_claude_cli and model:
            cmd_parts += ["--model", model]
        elif not use_claude_cli and model and agent_type in ("kimi", "gemini"):
            cmd_parts += ["--model", model]

        cmd_parts += cli_args

        start_cmd = " && ".join(exports + [" ".join(cmd_parts)]) if exports else " ".join(cmd_parts)

        out[name] = AgentSpec(
            name=name,
            tmux_session=tmux_session,
            start_cmd=start_cmd,
            cwd=cwd,
            status=str(a.get("status") or "active"),
            agent_type=agent_type,
            role=str(a.get("role") or "").strip(),
            group=str(a.get("group") or group_name).strip(),
            description=str(a.get("description") or "").strip(),
            raw_spec=dict(a),
        )
    return out


def _load_group_meta(config_dir: Path) -> dict[str, dict[str, Any]]:
    """Load group_meta from agents_registry.yaml."""
    from config.loader import YAMLConfigLoader

    loader = YAMLConfigLoader(config_dir=config_dir)
    cfg = loader.get_agents_registry()
    return cfg.get("group_meta", {}) if isinstance(cfg, dict) else {}


# Role priority for ordered startup (lower = start first)
_ROLE_START_ORDER = {"pmo": 0, "architect": 1, "devops": 2}
# Role priority for ordered shutdown (lower = stop first, reverse of start)
_ROLE_STOP_ORDER = {"pmo": 99, "architect": 98, "devops": 97}


def _resolve_targets(all_spec: dict[str, AgentSpec], names: list[str], *, all_flag: bool = False) -> list[AgentSpec]:
    if all_flag or names == ["all"]:
        return list(all_spec.values())
    if not names:
        raise RuntimeError("No agent specified. Use agent name(s) or --all")
    missing = [n for n in names if n not in all_spec]
    if missing:
        raise RuntimeError(f"Unknown agent(s): {', '.join(missing)}")
    return [all_spec[n] for n in names]


def _daemon_request(action: str, data: dict[str, Any]) -> dict[str, Any] | None:
    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.settimeout(3.0)
        sock.connect("/tmp/brain_ipc.sock")
        sock.sendall((json.dumps({"action": action, "data": data}, ensure_ascii=False) + "\n").encode("utf-8"))
        buf = b""
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            buf += chunk
            if b"\n" in buf:
                break
        sock.close()
        if not buf:
            return None
        return json.loads(buf.decode("utf-8"))
    except Exception:
        return None


def _update_desired_state(config_dir: Path, targets: list[AgentSpec], desired_state: str, *, apply: bool) -> None:
    normalized = str(desired_state or "").strip().lower()
    if normalized not in {"running", "stopped"}:
        raise RuntimeError("desired_state must be running|stopped")
    if not targets:
        return
    if not apply:
        for agent in targets:
            print(f"- {agent.name}: would set desired_state={normalized}")
        return

    config_path = config_dir / "agents_registry.yaml"
    with open(config_path, encoding="utf-8") as f:
        data = yaml.safe_load(f) or {}
    if not isinstance(data, dict):
        raise RuntimeError(f"invalid yaml root in {config_path}")

    target_names = {a.name for a in targets}
    found_names: set[str] = set()
    modified = 0

    for section_name in ("groups", "projects"):
        section = data.get(section_name)
        if not isinstance(section, dict):
            continue
        for _, agents in section.items():
            if not isinstance(agents, list):
                continue
            for agent in agents:
                if not isinstance(agent, dict):
                    continue
                name = str(agent.get("name") or "").strip()
                if name not in target_names:
                    continue
                found_names.add(name)
                current = str(agent.get("desired_state") or "running").strip().lower()
                if current != normalized:
                    agent["desired_state"] = normalized
                    modified += 1
                print(f"- {name}: desired_state={normalized}")

    missing = sorted(target_names - found_names)
    if missing:
        raise RuntimeError(f"agents not found in registry: {', '.join(missing)}")

    if modified > 0:
        with open(config_path, "w", encoding="utf-8") as f:
            yaml.dump(data, f, default_flow_style=False, sort_keys=False, allow_unicode=True)
        print(f"✓ Updated {config_path} ({modified} changed)")
    else:
        print(f"✓ desired_state already {normalized} for all targets")


def cmd_list(args: argparse.Namespace) -> int:
    """List configured agents and tmux status."""
    from config.loader import YAMLConfigLoader

    loader = YAMLConfigLoader(config_dir=Path(args.config_dir))
    cfg = loader.get_agents_registry()
    spec = _load_spec(Path(args.config_dir))
    sessions = _list_sessions()

    cfg_root = cfg.get("agents_registry", {}) if isinstance(cfg, dict) else {}
    agents = (cfg_root.get("agents") or []) if isinstance(cfg_root, dict) else []

    meta: dict[str, tuple[str, bool]] = {}
    if isinstance(agents, list):
        for a in agents:
            if not isinstance(a, dict):
                continue
            name = str(a.get("name") or "")
            if not name:
                continue
            meta[name] = (str(a.get("desired_state") or ""), bool(a.get("required", False)))

    for name in sorted(spec.keys()):
        agent_spec = spec[name]
        running = "running" if agent_spec.tmux_session in sessions else "stopped"
        desired_state, required_flag = meta.get(name, ("", False))
        required = "required" if required_flag else ""
        extra = " ".join([x for x in [desired_state, required] if x])
        extra_str = f" {extra}" if extra else ""
        print(f"{name:16s} {running:8s} session={agent_spec.tmux_session} status={agent_spec.status}{extra_str}")
    return 0


def cmd_online(args: argparse.Namespace) -> int:
    """Show daemon IPC online agents/instances."""
    resp = _daemon_request("agent_list", {"include_offline": False}) or {}
    if not (isinstance(resp, dict) and resp.get("status") == "ok"):
        print("daemon: unavailable")
        return 1
    instances = resp.get("instances", []) if isinstance(resp, dict) else []
    online_instances = []
    if isinstance(instances, list):
        for i in instances:
            if isinstance(i, dict) and i.get("online"):
                online_instances.append(i)
    unique_agents = sorted({str(i.get("agent_name") or "") for i in online_instances if i.get("agent_name")})
    print(f"online_instances={len(online_instances)} online_agents={len(unique_agents)}")
    for i in sorted(online_instances, key=lambda x: (str(x.get('agent_name') or ''), str(x.get('instance_id') or ''))):
        print(f"- {i.get('agent_name')} instance_id={i.get('instance_id')} idle_seconds={i.get('idle_seconds')}")
    return 0


def cmd_start(args: argparse.Namespace) -> int:
    """Start agent(s) by name, or 'all'."""
    spec = _load_spec(Path(args.config_dir))
    targets = _resolve_targets(spec, args.names, all_flag=getattr(args, "all", False))
    _update_desired_state(Path(args.config_dir), targets, "running", apply=bool(args.apply))
    config_gen = not getattr(args, "no_config_gen", False)
    force = getattr(args, "force", False)
    for agent in targets:
        _start_session(agent, apply=bool(args.apply), config_gen=config_gen, force_claude_md=force)
    return 0


def cmd_stop(args: argparse.Namespace) -> int:
    """Stop agent(s) by name, or 'all'."""
    spec = _load_spec(Path(args.config_dir))
    targets = _resolve_targets(spec, args.names, all_flag=getattr(args, "all", False))
    _update_desired_state(Path(args.config_dir), targets, "stopped", apply=bool(args.apply))
    for agent in targets:
        _kill_session(agent.tmux_session, apply=bool(args.apply))
    return 0


def cmd_restart(args: argparse.Namespace) -> int:
    """Restart agent(s) by name, or 'all'."""
    spec = _load_spec(Path(args.config_dir))
    targets = _resolve_targets(spec, args.names, all_flag=getattr(args, "all", False))
    _update_desired_state(Path(args.config_dir), targets, "running", apply=bool(args.apply))
    config_gen = not getattr(args, "no_config_gen", False)
    force = getattr(args, "force", False)
    for agent in targets:
        if not args.apply:
            cwd = agent.cwd or "/xkagent_infra/brain"
            cmd = agent.start_cmd or "<missing start_cmd>"
            print(f"- {agent.name}: would restart (stop: tmux kill-session -t {agent.tmux_session}; start: tmux new-session -d -s {agent.tmux_session} -c {cwd} {cmd})")
            continue
        _kill_session(agent.tmux_session, apply=True)
        _start_session(agent, apply=True, config_gen=config_gen, force_claude_md=force)
    return 0


def cmd_apply_config(args: argparse.Namespace) -> int:
    """Generate config files without restarting agents."""
    from services.config_generator import generate_all_configs

    spec = _load_spec(Path(args.config_dir))
    targets = _resolve_targets(spec, args.names, all_flag=getattr(args, "all", False))
    force = getattr(args, "force", False)

    for agent in targets:
        if not agent.raw_spec:
            print(f"- {agent.name}: skip (no raw_spec)")
            continue
        if not args.apply:
            mcp_file = ".codex/config.toml" if agent.agent_type == "codex" else ".mcp.json"
            print(f"- {agent.name}: would generate {mcp_file}", end="")
            if agent.role:
                md_name = "AGENTS.md" if agent.agent_type == "codex" else "CLAUDE.md"
                print(f" + {md_name}", end="")
            print()
            continue

        result = generate_all_configs(agent.raw_spec, force_claude_md=force)
        mcp_file = ".codex/config.toml" if agent.agent_type == "codex" else ".mcp.json"
        parts = [f"{mcp_file}"]
        if result.get("claude_md"):
            parts.append(os.path.basename(result["claude_md"]))
        print(f"- {agent.name}: generated {', '.join(parts)}")
    return 0


# ============================================================
# Group-level start/stop
# ============================================================

def cmd_start_group(args: argparse.Namespace) -> int:
    """Start all agents in a group, ordered by role priority."""
    spec = _load_spec(Path(args.config_dir))
    group_meta = _load_group_meta(Path(args.config_dir))
    group_name = args.group_name

    if group_name not in group_meta:
        print(f"ERROR: unknown group '{group_name}'. Known groups: {', '.join(sorted(group_meta.keys()))}", file=sys.stderr)
        return 1

    meta = group_meta[group_name]
    policy = meta.get("wake_policy", "manual")
    print(f"group={group_name} wake_policy={policy}")

    # Filter agents belonging to this group
    group_agents = [a for a in spec.values() if a.group == group_name]
    if not group_agents:
        print(f"  no agents found in group '{group_name}'")
        return 0

    # Sort by role: pmo → architect → devops → others
    group_agents.sort(key=lambda a: _ROLE_START_ORDER.get(a.role, 50))

    config_gen = not getattr(args, "no_config_gen", False)
    force = getattr(args, "force", False)
    for agent in group_agents:
        _start_session(agent, apply=bool(args.apply), config_gen=config_gen, force_claude_md=force)
    return 0


def cmd_stop_group(args: argparse.Namespace) -> int:
    """Stop all agents in a group, ordered by role priority (dev/qa first, pmo last)."""
    spec = _load_spec(Path(args.config_dir))
    group_meta = _load_group_meta(Path(args.config_dir))
    group_name = args.group_name

    if group_name not in group_meta:
        print(f"ERROR: unknown group '{group_name}'. Known groups: {', '.join(sorted(group_meta.keys()))}", file=sys.stderr)
        return 1

    print(f"group={group_name}")

    # Filter agents belonging to this group
    group_agents = [a for a in spec.values() if a.group == group_name]
    if not group_agents:
        print(f"  no agents found in group '{group_name}'")
        return 0

    # Sort by role: others first → devops → architect → pmo last
    group_agents.sort(key=lambda a: _ROLE_STOP_ORDER.get(a.role, 50))

    for agent in group_agents:
        _kill_session(agent.tmux_session, apply=bool(args.apply))
    return 0


# ============================================================
# Provision Group
# ============================================================

def cmd_provision_group(args: argparse.Namespace) -> int:
    """Provision a new group with standard agents (pmo, architect, devops)."""
    from config.loader import YAMLConfigLoader
    from services.provisioner import Provisioner, DEFAULT_GROUP_ROLES, ROLE_DEFAULTS

    group_id = args.group_id
    display_name = getattr(args, "name", "") or ""
    group_type = getattr(args, "type", "coding") or "coding"
    description = getattr(args, "description", "") or ""
    roles = getattr(args, "roles", None) or list(DEFAULT_GROUP_ROLES)
    desired_state = getattr(args, "desired_state", "stopped") or "stopped"

    if not args.apply:
        # Dry-run mode
        print(f"provision-group: {group_id} (dry-run)")
        print(f"  type: {group_type}")
        print(f"  description: {description or f'{display_name or group_id} group'}")
        print(f"  desired_state: {desired_state}")
        print(f"  roles: {', '.join(roles)}")
        print(f"  agents to create:")
        for role in roles:
            agent_name = f"agent_{group_id}_{role}"
            agent_dir = f"/xkagent_infra/groups/org/{group_id}/agents/{agent_name}"
            role_defaults = ROLE_DEFAULTS.get(role, {})
            model = role_defaults.get("agent_model", role_defaults.get("model", "Sonnet"))
            print(f"    - {agent_name} (role={role}, model={model}, cwd={agent_dir})")
        print(f"  files to generate:")
        for role in roles:
            agent_name = f"agent_{group_id}_{role}"
            agent_dir = f"/xkagent_infra/groups/org/{group_id}/agents/{agent_name}"
            print(f"    - {agent_dir}/CLAUDE.md")
            print(f"    - {agent_dir}/.mcp.json")
        print(f"    - /xkagent_infra/groups/org/{group_id}/workflow/pmo/agent_roster.yaml")
        print(f"\nRun with --apply to execute.")
        return 0

    # Apply mode
    loader = YAMLConfigLoader(config_dir=Path(args.config_dir))
    provisioner = Provisioner(config_loader=loader, launcher=None)

    try:
        created = provisioner.provision_group(
            group_id,
            display_name=display_name,
            group_type=group_type,
            description=description,
            roles=roles,
            desired_state=desired_state,
        )
    except ValueError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 1

    print(f"provision-group: {group_id} completed")
    for name in created:
        print(f"  created: {name}")
    print(f"  total: {len(created)} agents")
    return 0


def cmd_disable(args: argparse.Namespace) -> int:
    """Disable agent(s) by setting desired_state to stopped."""
    config_path = Path(args.config_dir) / "agents_registry.yaml"
    spec = _load_spec(Path(args.config_dir))
    targets = _resolve_targets(spec, args.names, all_flag=getattr(args, "all", False))

    if not args.apply:
        for agent in targets:
            print(f"- {agent.name}: would set desired_state=stopped")
        return 0

    # Load YAML
    with open(config_path) as f:
        data = yaml.safe_load(f)

    # Update desired_state
    modified = 0
    for group_name, agents in data.get('groups', {}).items():
        if agents:
            for agent in agents:
                if agent.get('name') in [t.name for t in targets]:
                    agent['desired_state'] = 'stopped'
                    modified += 1
                    print(f"- {agent.get('name')}: disabled (desired_state=stopped)")

    # Write back
    if modified > 0:
        with open(config_path, 'w') as f:
            yaml.dump(data, f, default_flow_style=False, sort_keys=False)
        print(f"\n✓ Updated {config_path}")
        print(f"✓ Modified {modified} agent(s)")
    else:
        print("✗ No agents modified")

    return 0


def cmd_enable(args: argparse.Namespace) -> int:
    """Enable agent(s) by setting desired_state to running."""
    config_path = Path(args.config_dir) / "agents_registry.yaml"
    spec = _load_spec(Path(args.config_dir))
    targets = _resolve_targets(spec, args.names, all_flag=getattr(args, "all", False))

    if not args.apply:
        for agent in targets:
            print(f"- {agent.name}: would set desired_state=running")
        return 0

    # Load YAML
    with open(config_path) as f:
        data = yaml.safe_load(f)

    # Update desired_state
    modified = 0
    for group_name, agents in data.get('groups', {}).items():
        if agents:
            for agent in agents:
                if agent.get('name') in [t.name for t in targets]:
                    agent['desired_state'] = 'running'
                    modified += 1
                    print(f"- {agent.get('name')}: enabled (desired_state=running)")

    # Write back
    if modified > 0:
        with open(config_path, 'w') as f:
            yaml.dump(data, f, default_flow_style=False, sort_keys=False)
        print(f"\n✓ Updated {config_path}")
        print(f"✓ Modified {modified} agent(s)")
    else:
        print("✗ No agents modified")

    return 0


def cmd_delete(args: argparse.Namespace) -> int:
    """Delete agent(s) from registry configuration."""
    config_path = Path(args.config_dir) / "agents_registry.yaml"
    spec = _load_spec(Path(args.config_dir))
    targets = _resolve_targets(spec, args.names, all_flag=getattr(args, "all", False))

    if not args.apply:
        for agent in targets:
            print(f"- {agent.name}: would delete from registry")
        print(f"\n⚠️  This will remove {len(targets)} agent(s) from {config_path}")
        print("⚠️  Agent directories and files will NOT be deleted (use 'purge' for that)")
        return 0

    # Confirm if not forced
    if not args.force:
        print(f"⚠️  About to delete {len(targets)} agent(s) from registry:")
        for agent in targets:
            print(f"   - {agent.name}")
        confirm = input("\nType 'yes' to confirm: ")
        if confirm.lower() != 'yes':
            print("✗ Cancelled")
            return 1

    # Load YAML
    with open(config_path) as f:
        data = yaml.safe_load(f)

    # Delete agents
    deleted = 0
    target_names = {t.name for t in targets}
    for group_name, agents in data.get('groups', {}).items():
        if agents:
            original_count = len(agents)
            agents[:] = [a for a in agents if a.get('name') not in target_names]
            deleted += original_count - len(agents)
            for name in target_names:
                if any(a.get('name') == name for a in agents[:original_count]):
                    print(f"- {name}: deleted from registry")

    # Write back
    if deleted > 0:
        with open(config_path, 'w') as f:
            yaml.dump(data, f, default_flow_style=False, sort_keys=False)
        print(f"\n✓ Updated {config_path}")
        print(f"✓ Deleted {deleted} agent(s)")
    else:
        print("✗ No agents deleted")

    return 0


def cmd_purge(args: argparse.Namespace) -> int:
    """Completely remove agent(s): stop tmux, delete config, delete directory."""
    config_path = Path(args.config_dir) / "agents_registry.yaml"
    spec = _load_spec(Path(args.config_dir))
    targets = _resolve_targets(spec, args.names, all_flag=getattr(args, "all", False))

    if not args.apply:
        for agent in targets:
            print(f"- {agent.name}: would purge")
            print(f"    • Stop tmux session: {agent.tmux_session}")
            for rp in _REGISTRY_PATHS:
                if rp.exists():
                    print(f"    • Delete from registry: {rp}")
            if agent.cwd:
                print(f"    • Delete directory: {agent.cwd}")
        print(f"\n⚠️  This is DESTRUCTIVE! Will remove {len(targets)} agent(s) completely")
        return 0

    # Confirm if not forced
    if not args.force:
        print(f"⚠️  About to PURGE {len(targets)} agent(s):")
        for agent in targets:
            print(f"   - {agent.name}")
            if agent.cwd:
                print(f"     Directory: {agent.cwd}")
        confirm = input("\nType 'DELETE' to confirm: ")
        if confirm != 'DELETE':
            print("✗ Cancelled")
            return 1

    purged = 0

    # Step 1: Stop tmux sessions
    print("\n=== Step 1: Stopping tmux sessions ===")
    for agent in targets:
        _kill_session(agent.tmux_session, apply=True)

    # Step 2: Delete from all registries
    print("\n=== Step 2: Deleting from registries ===")
    target_names = {t.name for t in targets}
    for rp in _REGISTRY_PATHS:
        if not rp.exists():
            continue
        try:
            with open(rp) as f:
                data = yaml.safe_load(f)
            removed = 0
            for group_name, agents in (data.get('groups', {}) or {}).items():
                if agents:
                    original_count = len(agents)
                    agents[:] = [a for a in agents if a.get('name') not in target_names]
                    removed += original_count - len(agents)
            if removed > 0:
                with open(rp, 'w') as f:
                    yaml.dump(data, f, default_flow_style=False, sort_keys=False)
                print(f"✓ {rp}: deleted {removed} agent(s)")
                purged += removed
            else:
                print(f"- {rp}: no matching agents")
        except Exception as e:
            print(f"✗ {rp}: {e}")

    # Step 3: Delete directories
    print("\n=== Step 3: Deleting directories ===")
    for agent in targets:
        if agent.cwd and Path(agent.cwd).exists():
            try:
                shutil.rmtree(agent.cwd)
                print(f"✓ {agent.name}: deleted directory {agent.cwd}")
            except Exception as e:
                print(f"✗ {agent.name}: failed to delete {agent.cwd}: {e}")
        else:
            print(f"- {agent.name}: no directory to delete")

    print(f"\n✓ Purged {purged} agent(s) completely")
    return 0


# ============================================================
# Rename agent
# ============================================================

def cmd_rename(args: argparse.Namespace) -> int:
    """Rename an agent: update registry fields, move directory, patch config files.

    Supports --group to move the agent to a different group.
    Default is dry-run; use --apply to execute.
    """
    old_name = args.old_name
    new_name = args.new_name
    new_group = getattr(args, "group", None) or None
    apply = bool(args.apply)

    # Load current spec to find the agent
    spec = _load_spec(Path(args.config_dir))
    if old_name not in spec:
        print(f"ERROR: agent '{old_name}' not found in registry", file=sys.stderr)
        return 1

    agent = spec[old_name]
    old_cwd = agent.cwd or ""
    old_group = agent.group

    # Determine target group and new directory path
    target_group = new_group or old_group
    if old_cwd:
        new_cwd = f"/xkagent_infra/groups/org/{target_group}/agents/{new_name}"
    else:
        new_cwd = ""

    # Dry-run: show what would happen
    if not apply:
        print(f"rename: {old_name} -> {new_name} (dry-run)")
        print(f"  group:        {old_group} -> {target_group}")
        print(f"  tmux_session: {old_name} -> {new_name}")
        if old_cwd:
            print(f"  directory:    {old_cwd}")
            print(f"             -> {new_cwd}")
        print(f"  registries to update:")
        for rp in _REGISTRY_PATHS:
            exists = "ok" if rp.exists() else "missing"
            print(f"    - {rp} ({exists})")
        if old_cwd:
            print(f"  config files to patch (name/path substitution):")
            for fname in ["CLAUDE.md", "AGENTS.md", ".mcp.json",
                          ".codex/config.toml", ".claude/settings.local.json"]:
                fp = Path(old_cwd) / fname
                if fp.exists():
                    print(f"    - {fp}")
        print(f"\nRun with --apply to execute.")
        return 0

    errors = 0

    # Step 1: Update all registry files
    print(f"\n=== Step 1: Updating registries ===")
    for rp in _REGISTRY_PATHS:
        if not rp.exists():
            print(f"skip {rp}: not found")
            continue
        try:
            with open(rp, encoding="utf-8") as f:
                data = yaml.safe_load(f) or {}

            found = False
            groups = data.get("groups", {})
            for grp_name, agents_list in list(groups.items()):
                if not isinstance(agents_list, list):
                    continue
                for i, ag in enumerate(agents_list):
                    if not isinstance(ag, dict):
                        continue
                    if str(ag.get("name") or "") != old_name:
                        continue
                    found = True
                    ag["name"] = new_name
                    ag["tmux_session"] = new_name
                    if new_cwd:
                        ag["cwd"] = new_cwd
                        ag["path"] = new_cwd
                    export_cmd = ag.get("export_cmd")
                    if isinstance(export_cmd, dict) and "BRAIN_AGENT_NAME" in export_cmd:
                        ag["export_cmd"]["BRAIN_AGENT_NAME"] = new_name
                    if ag.get("initial_prompt") == old_name:
                        ag["initial_prompt"] = new_name
                    if new_group and new_group != grp_name:
                        agents_list.pop(i)
                        if new_group not in groups:
                            groups[new_group] = []
                        groups[new_group].append(ag)
                        ag["group"] = new_group
                    break
                if found:
                    break

            if not found:
                print(f"skip {rp}: '{old_name}' not found")
                continue

            with open(rp, "w", encoding="utf-8") as f:
                yaml.dump(data, f, default_flow_style=False, sort_keys=False, allow_unicode=True)
            print(f"ok {rp}")
        except Exception as e:
            print(f"error {rp}: {e}")
            errors += 1

    # Step 2: Patch config files inside the agent directory (before mv)
    print(f"\n=== Step 2: Patching config files ===")
    if old_cwd and Path(old_cwd).exists():
        config_files = [
            Path(old_cwd) / "CLAUDE.md",
            Path(old_cwd) / "AGENTS.md",
            Path(old_cwd) / ".mcp.json",
            Path(old_cwd) / ".codex" / "config.toml",
            Path(old_cwd) / ".claude" / "settings.local.json",
        ]
        old_group_path = f"/xkagent_infra/groups/org/{old_group}/"
        new_group_path = f"/xkagent_infra/groups/org/{target_group}/"
        for cf in config_files:
            if not cf.exists():
                continue
            try:
                content = cf.read_text(encoding="utf-8")
                patched = content.replace(old_name, new_name)
                if old_cwd and new_cwd:
                    patched = patched.replace(old_cwd, new_cwd)
                if old_group != target_group:
                    patched = patched.replace(old_group_path, new_group_path)
                if patched != content:
                    cf.write_text(patched, encoding="utf-8")
                    print(f"patched {cf.name}")
                else:
                    print(f"no-op   {cf.name}")
            except Exception as e:
                print(f"error {cf}: {e}")
                errors += 1
    else:
        print("no config directory (cwd not set or missing)")

    # Step 3: Move the agent directory
    print(f"\n=== Step 3: Moving directory ===")
    if old_cwd and new_cwd:
        old_path = Path(old_cwd)
        new_path = Path(new_cwd)
        if old_path.exists():
            try:
                new_path.parent.mkdir(parents=True, exist_ok=True)
                shutil.move(str(old_path), str(new_path))
                print(f"moved {old_cwd}")
                print(f"   -> {new_cwd}")
            except Exception as e:
                print(f"error move: {e}")
                errors += 1
        else:
            print(f"skip: source directory not found: {old_cwd}")
    else:
        print("skip: no directory to move")

    if errors:
        print(f"\nrename completed with {errors} error(s)")
        return 1
    print(f"\nok: rename {old_name} -> {new_name} (group: {old_group} -> {target_group})")
    return 0


# ============================================================
# Add single agent
# ============================================================

# All known registry paths to keep in sync
_REGISTRY_PATHS = [
    Path("/xkagent_infra/brain/infrastructure/config/agentctl/agents_registry.yaml"),
    Path("/xkagent_infra/groups/org/brain_system/projects/agent_orchestrator/config/agents_registry.yaml"),
]


def cmd_profiles(args: argparse.Namespace) -> int:
    """List available type profiles, optionally filtered by role."""
    from services.provisioner import list_type_profiles

    profiles = list_type_profiles(role_filter=args.role)
    if not profiles:
        print("No profiles found.")
        return 0

    # Group by role for display
    from collections import defaultdict
    by_role: dict = defaultdict(list)
    for p in profiles:
        by_role[p["role"]].append(p)

    for role, variants in sorted(by_role.items()):
        print(f"\n[{role}]")
        for v in variants:
            default_mark = " (default)" if v.get("is_default") else ""
            print(f"  {v['id']}{default_mark}")
            cli = v.get("agent_cli", "")
            model = v.get("agent_model") or v.get("model", "")
            if cli:
                print(f"    agent_type={v['agent_type']}  agent_cli={cli}  agent_model={model}")
            else:
                print(f"    agent_type={v['agent_type']}  agent_model={model}")
            if v.get("reason"):
                print(f"    reason: {v['reason']}")
    print()
    return 0


def cmd_add(args: argparse.Namespace) -> int:
    """Add a single agent to registry, create directory, generate configs."""
    from config.registry_editor import AgentEntry, append_agent_to_group
    from services.provisioner import ROLE_DEFAULTS, ROLE_FALLBACK, load_type_profile

    name = args.name
    group = args.group
    role = args.role or ""

    # Auto-detect role from name: agent_{group}_{role} or agent_{alias}_{role}
    if not role:
        # Try exact group prefix first, then common aliases
        prefixes = [f"agent_{group}_"]
        # brain_system -> system, digital_resources -> dr, etc.
        parts = group.split("_")
        if len(parts) > 1:
            prefixes.append(f"agent_{parts[-1]}_")  # e.g. agent_system_
        for prefix in prefixes:
            if name.startswith(prefix):
                role = name[len(prefix):]
                break
        if not role:
            role = "custom"

    # Resolve --profile first; CLI flags override profile values
    profile_data = None
    if getattr(args, "profile", None):
        profile_data = load_type_profile(args.profile)
        if profile_data is None:
            print(f"ERROR: profile '{args.profile}' not found. Run 'agentctl profiles' to list available profiles.")
            return 1

    role_defaults = ROLE_DEFAULTS.get(role, ROLE_FALLBACK)
    agent_type = args.agent_type or (profile_data and profile_data["agent_type"]) or "claude"
    agent_cli = (
        args.agent_cli
        or args.cli_type
        or (profile_data and (profile_data.get("agent_cli") or profile_data.get("cli_type")))
        or role_defaults.get("agent_cli", "")
    )
    agent_model = (
        args.agent_model
        or args.model
        or (profile_data and (profile_data.get("agent_model") or profile_data.get("model")))
        or role_defaults.get("agent_model", "Sonnet")
    )
    effort = (profile_data and profile_data.get("effort")) or ""

    # Parse capabilities and tags
    if args.capabilities:
        capabilities = [c.strip() for c in args.capabilities.split(",") if c.strip()]
    else:
        capabilities = role_defaults.get("capabilities", [])

    if args.tags:
        tags = [t.strip() for t in args.tags.split(",") if t.strip()]
    else:
        tags = role_defaults.get("tags", [])

    desired_state = args.desired_state or "running"
    agent_dir = f"/xkagent_infra/groups/org/{group}/agents/{name}"

    entry = AgentEntry(
        name=name,
        tmux_session=name,
        cwd=agent_dir,
        description=f"{group} 的 {role} Agent",
        role=role,
        scope="group",
        group=group,
        path=agent_dir,
        agent_type=agent_type,
        agent_cli=agent_cli,
        agent_model=agent_model,
        effort=effort,
        cli_args=["--dangerously-skip-permissions"] if agent_type != "codex" else ["--dangerously-bypass-approvals-and-sandbox"],
        env={"IS_SANDBOX": "1"},
        export_cmd={"BRAIN_AGENT_NAME": name},
        required=False,
        desired_state=desired_state,
        status="active",
        capabilities=capabilities or None,
        tags=tags or None,
    )

    if not args.apply:
        print(f"add: {name} (dry-run)")
        print(f"  group: {group}")
        print(f"  role: {role}")
        print(f"  agent_type: {agent_type}")
        if agent_cli:
            print(f"  agent_cli: {agent_cli}")
        print(f"  agent_model: {agent_model}")
        print(f"  cwd: {agent_dir}")
        print(f"  desired_state: {desired_state}")
        print(f"  capabilities: {capabilities}")
        print(f"  tags: {tags}")
        print(f"\n  registries to update:")
        for rp in _REGISTRY_PATHS:
            exists = "✓" if rp.exists() else "✗ (missing)"
            print(f"    - {rp} {exists}")
        print(f"  directory to create: {agent_dir}")
        print(f"\nRun with --apply to execute.")
        return 0

    # Step 1: Create agent directory
    print(f"\n=== Step 1: Creating directory ===")
    agent_path = Path(agent_dir)
    agent_path.mkdir(parents=True, exist_ok=True)
    print(f"✓ {agent_dir}")

    # Step 2: Write to all registries
    print(f"\n=== Step 2: Updating registries ===")
    updated = 0
    for rp in _REGISTRY_PATHS:
        if not rp.exists():
            print(f"⚠ {rp}: not found, skipping")
            continue
        try:
            append_agent_to_group(rp, group, entry)
            print(f"✓ {rp}")
            updated += 1
        except Exception as e:
            print(f"✗ {rp}: {e}")

    # Step 3: Generate configs (CLAUDE.md + .mcp.json)
    print(f"\n=== Step 3: Generating configs ===")
    try:
        from services.config_generator import generate_all_configs
        # Default hooks based on role
        from services.provisioner import ROLE_DEFAULTS as _RD
        default_hooks = ["pre_tool_use", "session_start"]
        spec = {
            "name": name,
            "agent_type": agent_type,
            "agent_cli": agent_cli,
            "agent_model": agent_model,
            # legacy aliases for older generator code paths
            "cli_type": agent_cli,
            "model": agent_model,
            "effort": effort,
            "cwd": agent_dir,
            "role": role,
            "group": group,
            "path": agent_dir,
            "capabilities": capabilities,
            "hooks": default_hooks,
        }
        result = generate_all_configs(spec, force_claude_md=True)
        if result.get("claude_md"):
            print(f"✓ {result['claude_md']}")
        if result.get("mcp_config"):
            mcp_file = ".codex/config.toml" if agent_type == "codex" else ".mcp.json"
            print(f"✓ {agent_dir}/{mcp_file}")
        if result.get("settings_local"):
            print(f"✓ {result['settings_local']}")
    except Exception as e:
        print(f"⚠ config generation: {e}")

    print(f"\n✓ Added {name} to {updated} registry(ies)")
    return 0


# ============================================================
# Service Mode - IPC daemon
# ============================================================

def cmd_serve(args: argparse.Namespace) -> int:
    """Start IPC service daemon."""
    from services.agentctl_service import AgentCtlService, BrainDaemonClient, YAMLConfigLoader, AuditLogger

    # Use config from args
    loader = YAMLConfigLoader(config_dir=Path(args.config_dir))
    audit = AuditLogger(agent_name="service-agentctl", session=os.environ.get("TMUX_SESSION", ""))
    daemon = BrainDaemonClient(socket_path="/tmp/brain_ipc.sock")

    svc = AgentCtlService(
        agent_name="service-agentctl",
        daemon=daemon,
        config_loader=loader,
        audit=audit,
        poll_interval_s=0.2,
        outbound_agent="service_gateway_telegram",
        telegram_max_chars=3500,
        orchestrator_interval_s=10,
        cleanup_before_start=True,
        cleanup_timeout_seconds=5,
        cleanup_skip_attached=True,
    )
    asyncio.run(svc.run_forever())
    return 0


# ============================================================
# Main
# ============================================================

def main() -> int:
    parser = argparse.ArgumentParser(
        prog="brain-agentctl",
        description="Unified agent control: CLI operations and IPC service",
    )
    parser.add_argument(
        "--config-dir",
        default=os.environ.get("AGENTCTL_CONFIG_DIR", "/xkagent_infra/brain/infrastructure/config/agentctl"),
        help="Directory containing agents_registry.yaml",
    )

    sub = parser.add_subparsers(dest="cmd", required=True)

    # CLI commands
    sub.add_parser("list", help="List configured agents and tmux status")
    sub.add_parser("online", help="Show daemon IPC online agents/instances")

    p_start = sub.add_parser("start", help="Start agent(s) by name, or 'all'")
    p_start.add_argument("names", nargs="*", default=[])
    p_start.add_argument("--all", action="store_true", help="Target all agents")
    p_start.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")
    p_start.add_argument("--no-config-gen", action="store_true", help="Skip config file generation before start")
    p_start.add_argument("--force", action="store_true", help="Force overwrite existing CLAUDE.md/AGENTS.md")

    p_stop = sub.add_parser("stop", help="Stop agent(s) by name, or 'all'")
    p_stop.add_argument("names", nargs="*", default=[])
    p_stop.add_argument("--all", action="store_true", help="Target all agents")
    p_stop.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")

    p_restart = sub.add_parser("restart", help="Restart agent(s) by name, or 'all'")
    p_restart.add_argument("names", nargs="*", default=[])
    p_restart.add_argument("--all", action="store_true", help="Target all agents")
    p_restart.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")
    p_restart.add_argument("--no-config-gen", action="store_true", help="Skip config file generation before restart")
    p_restart.add_argument("--force", action="store_true", help="Force overwrite existing CLAUDE.md/AGENTS.md")

    p_apply = sub.add_parser("apply-config", help="Generate config files without restarting")
    p_apply.add_argument("names", nargs="*", default=[])
    p_apply.add_argument("--all", action="store_true", help="Target all agents")
    p_apply.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")
    p_apply.add_argument("--force", action="store_true", help="Force overwrite existing CLAUDE.md/AGENTS.md")

    # Agent lifecycle commands
    p_disable = sub.add_parser("disable", help="Disable agent(s) by setting desired_state=stopped")
    p_disable.add_argument("names", nargs="+", help="Agent name(s) to disable")
    p_disable.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")

    p_enable = sub.add_parser("enable", help="Enable agent(s) by setting desired_state=running")
    p_enable.add_argument("names", nargs="+", help="Agent name(s) to enable")
    p_enable.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")

    p_delete = sub.add_parser("delete", help="Delete agent(s) from registry (keeps directories)")
    p_delete.add_argument("names", nargs="+", help="Agent name(s) to delete")
    p_delete.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")
    p_delete.add_argument("--force", action="store_true", help="Skip confirmation prompt")

    p_purge = sub.add_parser("purge", help="Completely remove agent(s): stop + delete config + delete directory")
    p_purge.add_argument("names", nargs="+", help="Agent name(s) to purge")
    p_purge.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")
    p_purge.add_argument("--force", action="store_true", help="Skip confirmation prompt")

    # Rename agent
    p_rename = sub.add_parser("rename", help="Rename an agent: update registry, move directory, patch config files")
    p_rename.add_argument("old_name", help="Current agent name")
    p_rename.add_argument("new_name", help="New agent name")
    p_rename.add_argument("--group", default="", help="Move to a different group (e.g. foos)")
    p_rename.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")

    # Add single agent
    p_add = sub.add_parser("add", help="Add a single agent to registry and create directory")
    p_add.add_argument("name", help="Agent name (e.g. agent_system_ui-designer)")
    p_add.add_argument("--group", required=True, help="Target group (e.g. brain_system)")
    p_add.add_argument("--role", default="", help="Agent role (default: parsed from name)")
    p_add.add_argument("--agent-type", default="", help="AI provider: claude|codex|kimi|minimax|chatgpt|gemini|custom (default: claude)")
    p_add.add_argument("--agent-cli", default="", help="CLI type: claude|native (default: infer from agent_type)")
    p_add.add_argument("--agent-model", default="", help="Model name (default: from role template)")
    p_add.add_argument("--cli-type", default="", help="(compat) alias of --agent-cli")
    p_add.add_argument("--model", default="", help="(compat) alias of --agent-model")
    p_add.add_argument("--desired-state", default="running", choices=["stopped", "running"], help="Initial desired_state (default: running)")
    p_add.add_argument("--capabilities", default="", help="Comma-separated capabilities (default: from role template)")
    p_add.add_argument("--tags", default="", help="Comma-separated tags (default: from role template)")
    p_add.add_argument("--profile", default="", help="Type profile ID to preset agent_type+agent_model (e.g. TP-SD-ARCHITECT-CODEX-OPUS)")
    p_add.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")

    # Group-level commands
    p_start_group = sub.add_parser("start-group", help="Start all agents in a group")
    p_start_group.add_argument("group_name", help="Group name (e.g. digital_resources)")
    p_start_group.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")
    p_start_group.add_argument("--no-config-gen", action="store_true", help="Skip config file generation before start")
    p_start_group.add_argument("--force", action="store_true", help="Force overwrite existing CLAUDE.md/AGENTS.md")

    p_stop_group = sub.add_parser("stop-group", help="Stop all agents in a group")
    p_stop_group.add_argument("group_name", help="Group name (e.g. digital_resources)")
    p_stop_group.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")

    # Provision group command
    p_provision = sub.add_parser("provision-group", help="Provision a new group with standard agents")
    p_provision.add_argument("group_id", help="Group identifier (e.g. digital_resources)")
    p_provision.add_argument("--name", default="", help="Human-readable display name")
    p_provision.add_argument("--type", default="coding", choices=["coding", "service"], help="Group type (default: coding)")
    p_provision.add_argument("--description", default="", help="Group description")
    p_provision.add_argument("--roles", nargs="*", default=None, help="Roles to create (default: pmo architect devops)")
    p_provision.add_argument("--desired-state", default="stopped", choices=["stopped", "running"], help="Initial desired_state (default: stopped)")
    p_provision.add_argument("--apply", action="store_true", help="Actually perform action (default: dry-run)")

    # Profiles subcommand
    p_profiles = sub.add_parser("profiles", help="List available type profiles")
    p_profiles.add_argument("--role", default="", help="Filter by role (e.g. architect, developer, devops)")

    # Service command
    sub.add_parser("serve", help="Start IPC service daemon (accepts IPC messages)")

    args = parser.parse_args()

    # Route to command handler
    if args.cmd == "list":
        return cmd_list(args)
    elif args.cmd == "online":
        return cmd_online(args)
    elif args.cmd == "start":
        return cmd_start(args)
    elif args.cmd == "stop":
        return cmd_stop(args)
    elif args.cmd == "restart":
        return cmd_restart(args)
    elif args.cmd == "apply-config":
        return cmd_apply_config(args)
    elif args.cmd == "disable":
        return cmd_disable(args)
    elif args.cmd == "enable":
        return cmd_enable(args)
    elif args.cmd == "delete":
        return cmd_delete(args)
    elif args.cmd == "purge":
        return cmd_purge(args)
    elif args.cmd == "rename":
        return cmd_rename(args)
    elif args.cmd == "add":
        return cmd_add(args)
    elif args.cmd == "start-group":
        return cmd_start_group(args)
    elif args.cmd == "stop-group":
        return cmd_stop_group(args)
    elif args.cmd == "provision-group":
        return cmd_provision_group(args)
    elif args.cmd == "profiles":
        return cmd_profiles(args)
    elif args.cmd == "serve":
        return cmd_serve(args)
    else:
        parser.print_help()
        return 1


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        raise SystemExit(130)
