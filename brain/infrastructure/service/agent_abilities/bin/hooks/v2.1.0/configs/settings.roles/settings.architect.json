{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Glob|Grep|Read|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/brain/infrastructure/hooks/bin/current/pre_tool_use",
            "description": "LEP Engine - architect role (6 tools)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/brain/infrastructure/hooks/bin/current/post_tool_use",
            "description": "LEP Engine - Audit logging"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  }
}