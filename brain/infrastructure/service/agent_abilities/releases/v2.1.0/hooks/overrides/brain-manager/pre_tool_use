#!/usr/bin/env python3
"""brain-manager 专属 PreToolUse Hook

职责链:
  1. 检查 pending/MANIFEST.yaml → 收集 warn 消息
  2. 始终 chain 到全局 hook（LEP engine）
  3. 合并输出：全局 block 优先，pending warn 追加

触发条件:
  当 brain-manager 调用 deploy_publish / deploy_merge 等构建类 MCP tool 时，
  如果 pending 目录有未处理的 MANIFEST.yaml，输出 warn 提醒先处理 pending。

部署位置:
  agent-brain-manager/.claude/hooks/pre_tool_use（覆盖全局 entry）

源码位置:
  src/base/hooks/overrides/brain-manager/pre_tool_use
"""

import json
import os
import sys
import subprocess

PENDING_DIR = "/brain/runtime/update_brain/pending"
MANIFEST_PATH = os.path.join(PENDING_DIR, "MANIFEST.yaml")
UPDATE_BRAIN_SPEC = "/brain/base/workflow/operations/update_brain.yaml"
GLOBAL_HOOK = "/brain/base/hooks/pre_tool_use"

# 触发 pending 检查的 MCP tool 关键词
BUILD_KEYWORDS = ["deploy_publish", "deploy_merge", "deploy_build", "deploy_deploy"]


def check_pending(tool_name):
    """当调用构建类工具时，检查 pending 是否有未处理文件"""
    is_build_tool = any(kw in tool_name.lower() for kw in BUILD_KEYWORDS)
    if not is_build_tool:
        return None

    if not os.path.isfile(MANIFEST_PATH):
        return None

    try:
        import yaml
        with open(MANIFEST_PATH) as f:
            manifest = yaml.safe_load(f)

        if not manifest:
            return None

        files = manifest.get("files", [])
        if not files:
            return None

        batch_id = manifest.get("batch_id", "unknown")
        submitted_by = manifest.get("submitted_by", "unknown")
        file_count = len(files)

        file_list = "\n".join(
            f"  - {f.get('source', '?')} -> {f.get('target', '?')}"
            for f in files[:5]
        )
        if file_count > 5:
            file_list += f"\n  ... +{file_count - 5} more"

        return (
            f"⚠️ G-PENDING-CHECK: 发现未处理的 pending 更新！\n"
            f"\n"
            f"  batch_id: {batch_id}\n"
            f"  submitted_by: {submitted_by}\n"
            f"  文件数: {file_count}\n"
            f"{file_list}\n"
            f"\n"
            f"请先按操作手册处理 pending（Step 1-3），再执行构建。\n"
            f"操作规范: {UPDATE_BRAIN_SPEC}"
        )

    except Exception as e:
        return f"⚠️ G-PENDING-CHECK: pending/MANIFEST.yaml 读取失败: {e}"


def run_global_hook(raw_input):
    """调用全局 hook，返回 (stdout, stderr, returncode)"""
    if not (os.path.isfile(GLOBAL_HOOK) and os.access(GLOBAL_HOOK, os.X_OK)):
        return None, None, 0

    try:
        result = subprocess.run(
            [GLOBAL_HOOK],
            input=raw_input,
            capture_output=True,
            text=True,
            timeout=5
        )
        return result.stdout, result.stderr, result.returncode
    except Exception as e:
        print(f"Warning: global hook chain failed: {e}", file=sys.stderr)
        return None, None, 0


def main():
    raw_input = sys.stdin.read()
    try:
        data = json.loads(raw_input)
    except Exception:
        data = {}

    tool_name = data.get("tool_name", data.get("toolName", ""))

    # Step 1: pending 检查（仅收集消息，不退出）
    pending_msg = check_pending(tool_name)

    # Step 2: 始终 chain 到全局 hook（LEP engine）
    global_stdout, global_stderr, global_rc = run_global_hook(raw_input)

    # Step 3: 合并输出
    # 全局 hook block → 尊重 block（LEP 优先级最高）
    if global_rc == 2:
        if pending_msg:
            print(pending_msg, file=sys.stderr)
        if global_stderr:
            print(global_stderr, end="", file=sys.stderr)
        if global_stdout:
            print(global_stdout, end="")
        sys.exit(2)

    # 全局 hook pass/warn → 合并 pending warn
    if pending_msg:
        print(pending_msg, file=sys.stderr)
        if global_stderr:
            print(global_stderr, end="", file=sys.stderr)
        print(json.dumps({
            "hookSpecificOutput": {
                "hookEventName": "PreToolUse",
                "permissionDecision": "allow",
                "permissionDecisionReason": pending_msg
            }
        }, ensure_ascii=False))
        sys.exit(0)

    # 无 pending → 透传全局 hook 结果
    if global_stderr:
        print(global_stderr, end="", file=sys.stderr)
    if global_stdout:
        print(global_stdout, end="")
    else:
        print(json.dumps({
            "hookSpecificOutput": {"hookEventName": "PreToolUse"}
        }))
    sys.exit(global_rc)


if __name__ == "__main__":
    main()
