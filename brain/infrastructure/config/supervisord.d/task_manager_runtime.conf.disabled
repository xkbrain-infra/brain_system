# Task Manager Runtime Service Configuration for supervisord
# BS-025-task-manager-runtime

[program:task_manager_runtime]
command=python3 /brain/infrastructure/service/task_manager_runtime/src/main.py
directory=/brain/infrastructure/service/task_manager_runtime
autostart=false
autorestart=true
startretries=3
startsecs=3
stopasgroup=true
killasgroup=true
stdout_logfile=/brain/runtime/logs/task_manager_runtime.out.log
stderr_logfile=/brain/runtime/logs/task_manager_runtime.err.log
environment=BRAIN_AGENT_NAME="task_manager_runtime",TMR_HEALTH_PORT="8766",TMR_STATE_DIR="/brain/runtime/data/task_manager_runtime",TMR_PROJECTS_DIR="/brain/runtime/data/task_manager_runtime/projects",PYTHONPATH="/brain/infrastructure/service/task_manager_runtime/src"
