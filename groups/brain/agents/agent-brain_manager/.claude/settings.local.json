{
  "permissions": {
    "allow": [
      "Bash:*:*",
      "Read:*:*",
      "Edit:*:*",
      "Write:*:*",
      "Glob:*:*",
      "Grep:*:*",
      "Task:*:*",
      "Skill:*:*",
      "mcp__*:*",
      "AskUserQuestion:*:*",
      "NotebookEdit:*:*"
    ],
    "defaultMode": "bypassPermissions"
  },
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:8210",
    "ANTHROPIC_MODEL": "alibaba/kimi-k2.5",
    "ANTHROPIC_SMALL_FAST_MODEL": "alibaba/kimi-k2.5",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "alibaba/kimi-k2.5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "alibaba/kimi-k2.5",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "alibaba/kimi-k2.5",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "BRAIN_AGENT_ROLE": "brain-manager",
    "BRAIN_AGENT_GROUP": "brain",
    "BRAIN_SCOPE_PATH": "/brain/groups/org/brain",
    "BRAIN_AGENT_NAME": "agent-brain_manager",
    "ANTHROPIC_AUTH_TOKEN": "bgw-apx-v1--p-alibaba--m-kimi_k2_5--n-agent_brain_manager"
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name // \"Claude\"'); dir=$(echo \"$input\" | jq -r '.workspace.current_dir // \"~\"'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); if [ -n \"$used\" ]; then printf \"%s | %s | Context: %.1f%% used\" \"$model\" \"$dir\" \"$used\"; else printf \"%s | %s\" \"$model\" \"$dir\"; fi"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "greptile@claude-plugins-official": true
  },
  "language": "中文",
  "mcpServers": {
    "mcp-brain_ipc_c": {
      "command": "/brain/bin/mcp/mcp-brain_ipc_c",
      "args": [],
      "env": {
        "BRAIN_AGENT_NAME": "agent-brain_manager",
        "BRAIN_DAEMON_AUTOSTART": "0"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "spinnerTipsEnabled": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Glob|Grep|Read|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/brain/infrastructure/service/agent_abilities/bin/hooks/current/pre_tool_use",
            "timeout": 5000,
            "description": "LEP Engine - brain_manager PreToolUse",
            "env": {
              "BRAIN_AGENT_NAME": "agent-brain_manager",
              "BRAIN_AGENT_ROLE": "manager",
              "BRAIN_AGENT_GROUP": "brain",
              "BRAIN_SCOPE_PATH": "/brain/groups/org/brain"
            }
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Glob|Grep|Read|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/brain/infrastructure/service/agent_abilities/bin/hooks/current/post_tool_use",
            "timeout": 5000,
            "description": "LEP Engine - brain_manager PostToolUse audit",
            "env": {
              "BRAIN_AGENT_NAME": "agent-brain_manager",
              "BRAIN_AGENT_ROLE": "manager",
              "BRAIN_AGENT_GROUP": "brain",
              "BRAIN_SCOPE_PATH": "/brain/groups/org/brain"
            }
          }
        ]
      }
    ]
  }
}
