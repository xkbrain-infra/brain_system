{
  "version": 1,
  "agent_name": "agent-brain_devops",
  "runtime": {
    "command": "claude",
    "args": [
      "--model",
      "alibaba/kimi-k2.5",
      "--dangerously-skip-permissions",
      "agent-brain_devops"
    ],
    "env": {
      "IS_SANDBOX": "1",
      "BRAIN_TRANSPORT_MODE": "proxy",
      "BRAIN_AGENT_NAME": "agent-brain_devops"
    },
    "agent_type": "alibaba",
    "use_claude_cli": true
  }
}