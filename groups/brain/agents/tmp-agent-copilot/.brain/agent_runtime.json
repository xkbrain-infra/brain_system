{
  "version": 1,
  "agent_name": "tmp-agent-copilot",
  "runtime": {
    "command": "claude",
    "args": [
      "--model",
      "copilot/gpt-5-mini"
    ],
    "env": {
      "IS_SANDBOX": "1",
      "BRAIN_TRANSPORT_MODE": "proxy",
      "BRAIN_AGENT_NAME": "tmp-agent-copilot"
    },
    "agent_type": "copilot",
    "use_claude_cli": true
  }
}