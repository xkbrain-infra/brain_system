# Process Management Architecture
# 进程管理架构 - 启动层级与生命周期

process_management:
  version: "1.0"
  last_updated: "2026-02-05"

  overview: |
    Brain 系统采用分层进程管理架构：
    - L0: supervisord (容器 init 进程, PID 1)
    - L1: 基础服务 (brain_daemon, sshd, backend, frontend)
    - L2: Agent 编排器 (agent_orchestrator)
    - L3: 工作 Agent (claude, codex, 通过 tmux 管理)

  # =============================================================
  # 进程启动层级
  # =============================================================
  process_hierarchy:
    L0_init:
      name: supervisord
      role: "容器初始化进程 (PID 1)"
      config: "/etc/supervisor/conf.d/supervisord.conf"
      responsibilities:
        - "启动和监控所有 L1 服务"
        - "进程崩溃自动重启 (autorestart=true)"
        - "日志管理"
      note: "容器重启时自动启动所有已配置服务"

    L1_services:
      - name: brain_daemon
        command: "/brain/base/runtime/engine/src/daemon/v2/brain_daemon"
        priority: 10
        role: "IPC 基础设施层"
        provides:
          - "Unix socket 通信 (/tmp/brain_daemon.sock)"
          - "Agent 注册表"
          - "消息队列 (ACK/重试/死信)"
          - "审计日志"
          - "Tmux 发现"

      - name: agent_orchestrator
        command: "python3 -m agent_orchestrator.services.agent_orchestrator"
        priority: 20
        role: "Agent 编排层"
        depends_on: ["brain_daemon"]
        provides:
          - "消息路由 (Telegram → Agent)"
          - "Agent 生命周期管理"
          - "健康检查"
          - "命令处理 (/status, /help 等)"

      - name: backend
        command: "uvicorn backend.main:app"
        role: "Web API 服务"

      - name: frontend
        command: "npm run dev"
        role: "Web 前端服务"

      - name: sshd
        command: "/usr/sbin/sshd -D"
        role: "SSH 远程访问"

    L3_agents:
      managed_by: agent_orchestrator
      method: tmux
      registry: "/brain/groups/brain_system_group/projects/agent_orchestrator/config/agents_registry.yaml"
      agents:
        - name: claude
          tmux_session: claude_common
          start_cmd: "claude --resume"

        - name: codex
          tmux_session: codex_common
          start_cmd: "codex --resume"

        - name: codex_xkquant
          tmux_session: codex_xkquant
          start_cmd: "codex --resume"
          on_demand: true

  # =============================================================
  # 启动顺序
  # =============================================================
  startup_sequence:
    description: "容器启动时的进程初始化顺序"
    steps:
      1: "supervisord 启动 (PID 1)"
      2: "brain_daemon 启动 (priority=10)"
      3: "agent_orchestrator 启动 (priority=20, 等待 brain_daemon socket 就绪)"
      4: "backend/frontend/sshd 启动"
      5: "agent_orchestrator 根据 agents_registry.yaml 启动 claude/codex"

  # =============================================================
  # 关键配置文件
  # =============================================================
  config_files:
    supervisord:
      path: "/etc/supervisor/conf.d/supervisord.conf"
      description: "L0/L1 进程配置"

    agents_registry:
      path: "/brain/groups/brain_system_group/projects/agent_orchestrator/config/agents_registry.yaml"
      description: "L3 Agent 清单 (由 orchestrator 管理)"
      note: "不包含 orchestrator 自身，避免自引用"

  # =============================================================
  # 常见问题
  # =============================================================
  faq:
    - question: "agent_orchestrator 由谁启动？"
      answer: "由 supervisord 启动，不是由自己或其他 agent 启动"

    - question: "为什么 agents_registry.yaml 不包含 orchestrator？"
      answer: "orchestrator 是 L1 服务，由 supervisord 管理；registry 只包含 L3 agent"

    - question: "brain_daemon 和 agent_orchestrator 的关系？"
      answer: |
        brain_daemon 是 IPC 基础设施，提供消息传递能力
        agent_orchestrator 是业务层，使用 daemon 的 IPC 能力来管理 agent

  # =============================================================
  # 架构图 (ASCII)
  # =============================================================
  diagram: |
    ┌─────────────────────────────────────────────────────────┐
    │                    Docker Container                      │
    ├─────────────────────────────────────────────────────────┤
    │  L0: supervisord (PID 1)                                │
    │       │                                                  │
    │       ├── L1: brain_daemon      [IPC 基础设施]          │
    │       │        └── /tmp/brain_daemon.sock               │
    │       │                                                  │
    │       ├── L1: agent_orchestrator [Agent 编排]           │
    │       │        │                                         │
    │       │        └── L3: tmux sessions                    │
    │       │             ├── claude_common  (claude)         │
    │       │             ├── codex_common   (codex)          │
    │       │             └── codex_xkquant  (按需)           │
    │       │                                                  │
    │       ├── L1: backend           [Web API]               │
    │       ├── L1: frontend          [Web UI]                │
    │       └── L1: sshd              [SSH]                   │
    └─────────────────────────────────────────────────────────┘

metadata:
  author: "Brain System"
  related_docs:
    - "/brain/base/spec/core/architecture.yaml"
    - "/brain/base/spec/policies/agents/agent_protocol.yaml"
