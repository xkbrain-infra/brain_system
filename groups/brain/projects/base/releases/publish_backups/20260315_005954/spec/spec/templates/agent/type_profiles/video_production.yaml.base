# 短视频制作行业 Type Profiles

category: TP-CAT-VIDEO-PRODUCTION
version: "1.0"

profiles:

  scriptwriter:
    description: "脚本策划，选题构思，故事线设计"
    default: TP-VP-SCRIPTWRITER-CLAUDE-OPUS
    variants:
      - id: TP-VP-SCRIPTWRITER-CLAUDE-OPUS
        agent_type: claude
        cli_type: claude
        model: opus
        effort: high
        reason: "创意脚本需要深度推理和创作能力"

  editor:
    description: "视频剪辑，后期处理，特效合成"
    default: TP-VP-EDITOR-CLAUDE-SONNET
    variants:
      - id: TP-VP-EDITOR-CLAUDE-SONNET
        agent_type: claude
        cli_type: claude
        model: sonnet
        effort: medium
        reason: "剪辑指令生成需要视觉理解能力"

  publisher:
    description: "多平台发布，标题优化，标签管理"
    default: TP-VP-PUBLISHER-CLAUDE-HAIKU
    variants:
      - id: TP-VP-PUBLISHER-CLAUDE-HAIKU
        agent_type: claude
        cli_type: claude
        model: haiku
        effort: low
        reason: "发布流程标准化，速度优先"

  analyst:
    description: "数据分析，播放量/互动率追踪，竞品分析"
    default: TP-VP-ANALYST-CLAUDE-SONNET
    variants:
      - id: TP-VP-ANALYST-CLAUDE-SONNET
        agent_type: claude
        cli_type: claude
        model: sonnet
        effort: medium
        reason: "数据分析需要工具调用和推理"
