# 软件开发行业 Type Profiles

category: TP-CAT-SOFTWARE-DEV
version: "1.0"

profiles:

  architect:
    description: "技术设计，需要深度推理 + 全局视野"
    default: TP-SD-ARCHITECT-CLAUDE-OPUS
    variants:
      - id: TP-SD-ARCHITECT-CLAUDE-OPUS
        agent_type: claude
        cli_type: claude
        model: opus
        effort: high
        reason: "架构设计需要最强推理能力"
      - id: TP-SD-ARCHITECT-CODEX
        agent_type: codex
        cli_type: codex
        model: gpt-5.3-codex
        effort: xhigh
        reason: "无 hooks 限制，适合修改基础设施代码"

  developer:
    description: "编码实现，可多实例"
    default: TP-SD-DEV-CLAUDE-SONNET
    variants:
      - id: TP-SD-DEV-CLAUDE-SONNET
        agent_type: claude
        cli_type: claude
        model: sonnet
        effort: medium
        reason: "通用开发，工具调用 + 代码能力均衡"
      - id: TP-SD-DEV-CODEX-OPENAI
        agent_type: codex
        cli_type: codex
        model: gpt-5.3-codex
        effort: xhigh
        reason: "OpenAI Codex 擅长代码补全和重构"
      - id: TP-SD-DEV-MINIMAX
        agent_type: minimax
        cli_type: claude
        model: MiniMax-M2.5
        reason: "成本敏感场景，简单编码任务"

  devops:
    description: "运维部署，Bash 工具 + 基础设施写权限"
    default: TP-SD-DEVOPS-CLAUDE-SONNET
    variants:
      - id: TP-SD-DEVOPS-CLAUDE-SONNET
        agent_type: claude
        cli_type: claude
        model: sonnet
        effort: medium
        reason: "需要工具调用能力操作基础设施"

  qa:
    description: "测试验证，可多实例"
    default: TP-SD-QA-CODEX-MEDIUM
    variants:
      - id: TP-SD-QA-CODEX-MEDIUM
        agent_type: codex
        cli_type: codex
        model: gpt-5.3-codex
        effort: xhigh
        reason: "测试执行标准化，xhigh effort 保证质量"
      - id: TP-SD-QA-CODEX-HIGH
        agent_type: codex
        cli_type: codex
        model: gpt-5.3-codex
        effort: high
        reason: "复杂集成测试场景"

  researcher:
    description: "技术调研，信息收集与分析"
    default: TP-SD-RESEARCHER-CODEX-HIGH
    variants:
      - id: TP-SD-RESEARCHER-CODEX-HIGH
        agent_type: codex
        cli_type: codex
        model: gpt-5.3-codex
        effort: high
        reason: "研究需要大量上下文处理"

  ui-designer:
    description: "UI/前端设计"
    default: TP-SD-UI-CLAUDE-SONNET
    variants:
      - id: TP-SD-UI-CLAUDE-SONNET
        agent_type: claude
        cli_type: claude
        model: sonnet
        effort: medium
        reason: "前端代码生成需要视觉理解能力"
