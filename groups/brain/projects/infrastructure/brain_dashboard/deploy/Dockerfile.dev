# Brain Dashboard Development Sandbox
FROM python:3.11-slim

WORKDIR /workspace

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    sqlite3 \
    inotify-tools \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt* ./
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn[standard] \
    httpx \
    aiofiles \
    psutil \
    pytest \
    pytest-asyncio

# Create workspace structure
RUN mkdir -p /workspace/project /workspace/data /workspace/logs

# Set environment
ENV PYTHONPATH=/workspace/project/src
ENV BRAIN_DASHBOARD_ENV=sandbox
ENV BRAIN_DASHBOARD_DATA=/workspace/data

WORKDIR /workspace/project

CMD ["bash"]
