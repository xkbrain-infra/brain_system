{
  "permissions": {
    "allow": [
      "mcp__brain-ipc-c__ipc_register",
      "Bash(echo:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Glob|Grep|Read|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/brain/infrastructure/service/agent_abilities/bin/hooks/current/pre_tool_use",
            "timeout": 5000,
            "env": {
              "BRAIN_AGENT_NAME": "agent_system_devops",
              "BRAIN_AGENT_ROLE": "devops",
              "BRAIN_AGENT_GROUP": "brain_system",
              "BRAIN_SCOPE_PATH": "/brain/groups/org/brain_system"
            }
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Glob|Grep|Read|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/brain/infrastructure/service/agent_abilities/bin/hooks/current/post_tool_use",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/brain/infrastructure/service/agent_abilities/bin/hooks/current/stop_hook",
            "timeout": 3000,
            "description": "IPC auto-wake: check pending messages before stopping",
            "env": {
              "BRAIN_AGENT_NAME": "agent-system_devops",
              "BRAIN_IPC_SOCKET": "/tmp/brain_ipc.sock"
            }
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name // \"Claude\"'); dir=$(echo \"$input\" | jq -r '.workspace.current_dir // \"~\"'); used=$(echo \"$input\" | jq -r '((.context_window.used_percentage | select(. > 0)) // (if ((.context_window.currentTokens // 0) > 0 and (.context_window.tokenLimit // 0) > 0) then ((.context_window.currentTokens / .context_window.tokenLimit) * 100) else empty end) // (if ((.context_window.current_tokens // 0) > 0 and (.context_window.token_limit // 0) > 0) then ((.context_window.current_tokens / .context_window.token_limit) * 100) else empty end) // (if ((.usage_info.currentTokens // 0) > 0 and (.usage_info.tokenLimit // 0) > 0) then ((.usage_info.currentTokens / .usage_info.tokenLimit) * 100) else empty end) // (if ((.usage_info.current_tokens // 0) > 0 and (.usage_info.token_limit // 0) > 0) then ((.usage_info.current_tokens / .usage_info.token_limit) * 100) else empty end) // empty)'); if [ -z \"$used\" ] || [ \"$used\" = \"null\" ] || [ \"$used\" = \"0\" ] || [ \"$used\" = \"0.0\" ]; then transcript=$(echo \"$input\" | jq -r '.transcript_path // empty'); window=$(echo \"$input\" | jq -r '(.context_window.context_window_size // .context_window.tokenLimit // .context_window.token_limit // .usage_info.tokenLimit // .usage_info.token_limit // 0)'); if [ -n \"$transcript\" ] && [ ! -f \"$transcript\" ]; then tdir=$(dirname \"$transcript\"); if [ -d \"$tdir\" ]; then transcript=$(ls -t \"$tdir\"/*.jsonl 2>/dev/null | head -1); fi; fi; if [ -n \"$transcript\" ] && [ -f \"$transcript\" ] && [ \"$window\" != \"0\" ]; then tokens=$(jq -s '[ .[] | .message?.usage? | ((.input_tokens // 0) + (.output_tokens // 0) + (.cache_read_input_tokens // 0) + (.cache_creation_input_tokens // 0)) ] | add // 0' \"$transcript\" 2>/dev/null); if [ -n \"$tokens\" ] && [ \"$tokens\" != \"0\" ]; then used=$(awk -v t=\"$tokens\" -v w=\"$window\" 'BEGIN { printf \"%.1f\", (t * 100.0) / w }'); fi; fi; fi; if [ -n \"$used\" ] && [ \"$used\" != \"null\" ] && [ \"$used\" != \"0\" ] && [ \"$used\" != \"0.0\" ]; then printf \"%s | %s | Context: %.1f%% used\" \"$model\" \"$dir\" \"$used\"; else printf \"%s | %s | Context: n/a\" \"$model\" \"$dir\"; fi"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "greptile@claude-plugins-official": true
  },
  "language": "中文",
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {},
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:8200",
    "ANTHROPIC_MODEL": "copilot/claude-sonnet-4.6",
    "ANTHROPIC_SMALL_FAST_MODEL": "copilot/claude-sonnet-4.6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "copilot/claude-sonnet-4.6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "copilot/claude-sonnet-4.6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "copilot/claude-sonnet-4.6",
    "ANTHROPIC_AUTH_TOKEN": "bgw-apx-v1--p-copilot--n-agent-system_devops"
  }
}
